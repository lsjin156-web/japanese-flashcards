  },
  {
    "id": 338,
    "japanese": "올바른 문장",
    "korean": "旅行に行こうと思います。",
    "romaji": "りょこうにいこうとおもいます。",
    "english": "ryokō ni ikō to omoimasu",
    "source": "료코우니 이코우토 오모이마스",
    "added_date": "2026-04-26T03:06:31.660539"
  },
  {
    "id": 339,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660547"
  },
  {
    "id": 340,
    "japanese": "",
    "korean": "紹介されました。",
    "romaji": "しょうかいされました。",
    "english": "shōkai saremashita",
    "source": "쇼우카이사레마시타",
    "added_date": "2026-04-26T03:06:31.660556"
  },
  {
    "id": 341,
    "japanese": "",
    "korean": "予約しないで食べられますか。",
    "romaji": "よやくしないでたべられますか。",
    "english": "yoyaku shinaide taberaremasu ka",
    "source": "요야쿠 시나이데 타베라레마스카",
    "added_date": "2026-04-26T03:06:31.660565"
