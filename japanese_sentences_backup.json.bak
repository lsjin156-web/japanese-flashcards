  },
  {
    "id": 906,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663927"
  },
  {
    "id": 907,
    "japanese": "",
    "korean": "財布をなくしてしまいました。",
    "romaji": "さいふ を なくして しまいました",
    "english": "saifu o nakushite shimaimashita",
    "source": "사이후오 나쿠시테 시마이마시타",
    "added_date": "2026-04-26T03:06:31.663933"
  },
  {
