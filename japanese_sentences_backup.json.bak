    "added_date": "2026-04-26T03:06:31.663912"
  },
  {
    "id": 904,
    "japanese": "",
    "korean": "迷惑をかける",
    "romaji": "めいわく を かける",
    "english": "meiwaku o kakeru",
    "source": "메이와쿠오 카케루",
    "added_date": "2026-04-26T03:06:31.663917"
  },
  {
    "id": 905,
