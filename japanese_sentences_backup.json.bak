  },
  {
    "id": 521,
    "japanese": "",
    "korean": "昨日から熱があるようです。",
    "romaji": "きのう から ねつ が ある ようです",
    "english": "kinō kara netsu ga aru yō desu",
    "source": "기노오 카라 네츠가 아루 요우데스",
    "added_date": "2026-04-26T03:06:31.661591"
  },
  {
    "id": 522,
    "japanese": "",
    "korean": "せきも出ますか。",
    "romaji": "せき も でます か",
    "english": "seki mo demasu ka",
    "source": "세키 모 데마스카",
    "added_date": "2026-04-26T03:06:31.661597"
  },
  {
    "id": 523,
    "japanese": "",
    "korean": "はい、薬を飲めばいいですか。",
    "romaji": "はい、くすり を のめば いい です か",
    "english": "hai, kusuri o nomeba ii desu ka",
    "source": "하이 쿠스리오 노메바 이이데스카",
    "added_date": "2026-04-26T03:06:31.661601"
  },
  {
    "id": 524,
    "japanese": "",
    "korean": "風邪かもしれません。薬を飲んで休んだ方がいいですね。",
    "romaji": "かぜ かも しれません。くすり を のんで やすんだ ほう が いい です ね",
    "english": "kaze kamo shiremasen. kusuri o nonde yasunda hō ga ii desu ne",
    "source": "카제 카모 시레마센. 쿠스리오 논데 야슨다 호오가 이이데스네",
    "added_date": "2026-04-26T03:06:31.661605"
  },
  {
    "id": 525,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661609"
  },
  {
    "id": 526,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661616"
  },
  {
    "id": 527,
    "japanese": "",
    "korean": "食べ放題は、同じ料金でいくらでも食べられます。",
    "romaji": "たべほうだい は、おなじ りょうきん で いくらでも たべられます",
    "english": "tabehōdai wa, onaji ryōkin de ikura demo taberaremasu",
    "source": "타베호우다이 와, 오나지 료오킨데 이쿠라데모 타베라레마스",
    "added_date": "2026-04-26T03:06:31.661620"
  },
  {
    "id": 528,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661624"
  },
  {
    "id": 529,
    "japanese": "",
    "korean": "日本人はよくお茶を飲みます。",
    "romaji": "にほんじん は よく おちゃ を のみます",
    "english": "nihonjin wa yoku ocha o nomimasu",
    "source": "니혼진와 요쿠 오챠오 노미마스",
    "added_date": "2026-04-26T03:06:31.661628"
  },
  {
    "id": 530,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661631"
  },
  {
    "id": 531,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661635"
  },
  {
    "id": 532,
    "japanese": "",
    "korean": "明日は雨が降るようです。",
    "romaji": "あした は あめ が ふる よう です",
    "english": "ashita wa ame ga furu yō desu",
    "source": "아시타와 아메가 후루 요우데스",
    "added_date": "2026-04-26T03:06:31.661639"
  },
  {
    "id": 533,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661643"
  },
  {
    "id": 534,
    "japanese": "",
    "korean": "雨は降らないようです。",
    "romaji": "あめ は ふらない よう です",
    "english": "ame wa furanai yō desu",
    "source": "아메와 후라나이 요우데스",
    "added_date": "2026-04-26T03:06:31.661647"
  },
  {
    "id": 535,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661651"
  },
  {
    "id": 536,
    "japanese": "",
    "korean": "降ったほうがいいです。",
    "romaji": "ふった ほう が いい です",
    "english": "futta hō ga ii desu",
    "source": "훗타 호오가 이이데스",
    "added_date": "2026-04-26T03:06:31.661655"
  },
  {
    "id": 537,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661659"
  },
  {
    "id": 538,
    "japanese": "",
    "korean": "雨が降るかもしれません。",
    "romaji": "あめ が ふる かも しれません",
    "english": "ame ga furu kamo shiremasen",
    "source": "아메가 후루 카모 시레마센",
    "added_date": "2026-04-26T03:06:31.661663"
  },
  {
    "id": 539,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661667"
  },
  {
    "id": 540,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661671"
  },
  {
    "id": 541,
    "japanese": "",
    "korean": "雨が降れば行きません。",
    "romaji": "あめ が ふれば いきません",
    "english": "ame ga fureba ikimasen",
    "source": "아메가 후레바 이키마센",
    "added_date": "2026-04-26T03:06:31.661677"
  },
  {
    "id": 542,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661680"
  },
  {
    "id": 543,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661684"
  },
  {
    "id": 544,
    "japanese": "",
    "korean": "雨が降れば行かないほうがいいです。",
    "romaji": "あめ が ふれば いかない ほう が いい です",
    "english": "ame ga fureba ikanai hō ga ii desu",
    "source": "아메가 후레바 이카나이 호오가 이이데스",
    "added_date": "2026-04-26T03:06:31.661688"
  },
  {
    "id": 545,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661692"
  },
  {
    "id": 546,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661699"
  },
  {
    "id": 547,
    "japanese": "",
    "korean": "頭が痛いから薬を飲みました。",
    "romaji": "あたま が いたい から くすり を のみました",
    "english": "atama ga itai kara kusuri o nomimashita",
    "source": "아타마가 이타이 카라 쿠스리오 노미마시타",
    "added_date": "2026-04-26T03:06:31.661703"
  },
  {
    "id": 548,
    "japanese": "",
    "korean": "具合が悪いから家で休みました。",
    "romaji": "ぐあい が わるい から いえ で やすみました",
    "english": "guai ga warui kara ie de yasumimashita",
    "source": "구아이 가 와루이 카라 이에데 야수미마시타",
    "added_date": "2026-04-26T03:06:31.661707"
  },
  {
    "id": 549,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661710"
  },
  {
    "id": 550,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661715"
  },
  {
    "id": 551,
    "japanese": "",
    "korean": "熱がある",
    "romaji": "ねつが ある",
    "english": "netsu ga aru",
    "source": "네츠가 아루",
    "added_date": "2026-04-26T03:06:31.661719"
  },
  {
    "id": 552,
    "japanese": "",
    "korean": "頭が痛い",
    "romaji": "あたまが いたい",
    "english": "atama ga itai",
    "source": "아타마가 이타이",
    "added_date": "2026-04-26T03:06:31.661723"
  },
  {
    "id": 553,
    "japanese": "",
    "korean": "喉がはれる",
    "romaji": "のどが はれる",
    "english": "nodo ga hareru",
    "source": "노도가 하레루",
    "added_date": "2026-04-26T03:06:31.661726"
  },
  {
    "id": 554,
    "japanese": "",
    "korean": "咳が出る",
    "romaji": "せきが でる",
    "english": "seki ga deru",
    "source": "세키가 데루",
    "added_date": "2026-04-26T03:06:31.661731"
  },
  {
    "id": 555,
    "japanese": "",
    "korean": "口を開ける",
    "romaji": "くちを あける",
    "english": "kuchi o akeru",
    "source": "쿠치오 아케루",
    "added_date": "2026-04-26T03:06:31.661735"
  },
  {
    "id": 556,
    "japanese": "",
    "korean": "風邪を引く",
    "romaji": "かぜを ひく",
    "english": "kaze o hiku",
    "source": "카제오 히쿠",
    "added_date": "2026-04-26T03:06:31.661739"
  },
  {
    "id": 557,
    "japanese": "",
    "korean": "薬を飲む",
    "romaji": "くすりを のむ",
    "english": "kusuri o nomu",
    "source": "쿠스리오 노무",
    "added_date": "2026-04-26T03:06:31.661743"
  },
  {
    "id": 558,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661747"
  },
  {
    "id": 559,
    "japanese": "",
    "korean": "頭が痛いから薬を飲みました。",
    "romaji": "あたまが いたい から くすりを のみました",
    "english": "atama ga itai kara kusuri o nomimashita",
    "source": "아타마가 이타이 카라 쿠스리오 노미마시타",
    "added_date": "2026-04-26T03:06:31.661751"
  },
  {
    "id": 560,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661755"
  },
  {
    "id": 561,
    "japanese": "",
    "korean": "具合が悪いから家で休みました。",
    "romaji": "ぐあいが わるい から いえで やすみました",
    "english": "guai ga warui kara ie de yasumimashita",
    "source": "구아이가 와루이 카라 이에데 야스미마시타",
    "added_date": "2026-04-26T03:06:31.661759"
  },
  {
    "id": 562,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661763"
  },
  {
    "id": 563,
    "japanese": "",
    "korean": "喉が腫れていますね。",
    "romaji": "のどが はれています ね",
    "english": "nodo ga hareteimasu ne",
    "source": "노도가 하레테이마스네",
    "added_date": "2026-04-26T03:06:31.661767"
  },
  {
    "id": 564,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661771"
  },
  {
    "id": 565,
    "japanese": "",
    "korean": "口を大きく開けてみてください。",
    "romaji": "くちを おおきく あけて みて ください",
    "english": "kuchi o ōkiku akete mite kudasai",
    "source": "쿠치오 오오키쿠 아케테 미테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.661776"
  },
  {
