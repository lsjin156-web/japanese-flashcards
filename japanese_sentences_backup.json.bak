  },
  {
    "id": 586,
    "japanese": "",
    "korean": "1. 忘れてしまったようです。",
    "romaji": "わすれて しまった ようです",
    "english": "wasurete shimatta yō desu",
    "source": "와스레테 시맛타 요우데스",
    "added_date": "2026-04-26T03:06:31.661875"
  },
  {
    "id": 587,
    "japanese": "",
    "korean": "2. 落としてしまったようです。",
    "romaji": "おとして しまった ようです",
    "english": "otoshite shimatta yō desu",
    "source": "오토시테 시맛타 요우데스",
    "added_date": "2026-04-26T03:06:31.661885"
  },
  {
    "id": 588,
    "japanese": "",
    "korean": "3. 壊してしまったようです。",
    "romaji": "こわして しまった ようです",
    "english": "kowashite shimatta yō desu",
    "source": "코와시테 시맛타 요우데스",
    "added_date": "2026-04-26T03:06:31.661892"
  },
  {
    "id": 589,
    "japanese": "",
    "korean": "4. 消してしまったようです。",
    "romaji": "けして しまった ようです",
    "english": "keshite shimatta yō desu",
    "source": "케시테 시맛타 요우데스",
    "added_date": "2026-04-26T03:06:31.661898"
  },
  {
    "id": 590,
    "japanese": "",
    "korean": "5. なくしてしまったようです。",
    "romaji": "なくして しまった ようです",
    "english": "nakushite shimatta yō desu",
    "source": "나쿠시테 시맛타 요우데스",
    "added_date": "2026-04-26T03:06:31.661905"
  },
  {
    "id": 591,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661912"
  },
  {
    "id": 592,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661920"
  },
  {
    "id": 593,
    "japanese": "",
    "korean": "食べておいたほうがいいです",
    "romaji": "たべておいたほうがいいです",
    "english": "tabete oita hōga ii desu",
    "source": "타베테 오이타 호오가 이이 데스",
    "added_date": "2026-04-26T03:06:31.661928"
  },
  {
    "id": 594,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661935"
  },
  {
    "id": 595,
    "japanese": "",
    "korean": "風邪をひかないように気をつけてください",
    "romaji": "かぜをひかないように きをつけてください",
    "english": "kaze o hikanai yō ni ki o tsukete kudasai",
    "source": "카제오 히카나이 요오니 키오 츠케테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.661942"
  },
  {
    "id": 596,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661948"
  },
  {
    "id": 597,
    "japanese": "",
    "korean": "インフルエンザにかからないように",
    "romaji": "いんふるえんざに かからないように",
    "english": "infuruenza ni kakaranai yō ni",
    "source": "인후루엔자 니 카카라나이 요오니",
    "added_date": "2026-04-26T03:06:31.661955"
  },
