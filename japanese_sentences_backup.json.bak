  },
  {
    "id": 621,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662095"
  },
  {
    "id": 622,
    "japanese": "",
    "korean": "インフルにかからないように",
    "romaji": "いんふるに かからないように",
    "english": "infuru ni kakaranai yō ni",
    "source": "인후루니 카카라나이요오니",
    "added_date": "2026-04-26T03:06:31.662100"
