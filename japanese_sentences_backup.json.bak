    "added_date": "2026-04-26T03:06:31.661337"
  },
  {
    "id": 462,
    "japanese": "",
    "korean": "あなたに会うために今まで待っていました。",
    "romaji": "あなたに あうために いままで まっていました",
    "english": "anata ni au tame ni ima made matte imashita",
    "source": "아나타니 아우 타메니 이마마데 맛테이마시타",
    "added_date": "2026-04-26T03:06:31.661344"
  },
  {
    "id": 463,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661349"
  },
  {
    "id": 464,
    "japanese": "",
    "korean": "日本語が上手になるために",
    "romaji": "にほんごが じょうずに なる ために",
    "english": "nihongo ga jōzu ni naru tame ni",
    "source": "니홍고가 죠오즈니 나루 타메니",
    "added_date": "2026-04-26T03:06:31.661354"
  },
  {
    "id": 465,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661359"
  },
  {
    "id": 466,
    "japanese": "",
    "korean": "会えるために",
    "romaji": "あえる ために",
    "english": "aeru tame ni",
    "source": "아에루 타메니",
    "added_date": "2026-04-26T03:06:31.661364"
  },
  {
    "id": 467,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661369"
  },
  {
    "id": 468,
    "japanese": "2025-11-19",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661377"
  },
  {
    "id": 469,
    "japanese": "",
    "korean": "粘り強く勉強します。",
    "romaji": "ねばりづよく べんきょうします",
    "english": "nebarizuyoku benkyō shimasu",
    "source": "네바리즈요쿠 벤쿄오시마스",
    "added_date": "2026-04-26T03:06:31.661381"
  },
  {
    "id": 470,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661385"
  },
  {
    "id": 471,
    "japanese": "",
    "korean": "彼は我慢強い人です。",
    "romaji": "かれは がまんつよい ひとです",
    "english": "kare wa gamantsuyoi hito desu",
    "source": "카레와 가만츠요이 히토데스",
    "added_date": "2026-04-26T03:06:31.661389"
  },
  {
    "id": 472,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661392"
  },
  {
    "id": 473,
    "japanese": "",
    "korean": "日本語が上手になるために",
    "romaji": "にほんごが じょうずに なる ために",
    "english": "nihongo ga jōzu ni naru tame ni",
    "source": "니홍고가 조오즈니 나루 타메니",
    "added_date": "2026-04-26T03:06:31.661394"
  },
  {
    "id": 474,
    "japanese": "",
    "korean": "毎日勉強してください",
    "romaji": "まいにち べんきょうしてください",
    "english": "mainichi benkyō shite kudasai",
    "source": "마이니치 벤쿄오 시테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.661398"
  },
  {
    "id": 475,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661401"
  },
  {
    "id": 476,
    "japanese": "",
    "korean": "朝7時に家を出なければなりません",
    "romaji": "あさ しちじに いえを でなければ なりません",
    "english": "asa shichiji ni ie o denakereba narimasen",
    "source": "아사 시치지니 이에오 데나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661405"
  },
  {
    "id": 477,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661408"
  },
  {
    "id": 478,
    "japanese": "",
    "korean": "宿題をしなければなりません",
    "romaji": "しゅくだいを しなければ なりません",
    "english": "shukudai o shinakereba narimasen",
    "source": "슈쿠다이오 시나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661411"
  },
  {
    "id": 479,
    "japanese": "",
    "korean": "早く寝なければなりません",
    "romaji": "はやく ねなければ なりません",
    "english": "hayaku nenakereba narimasen",
    "source": "하야쿠 네나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661415"
  },
  {
    "id": 480,
    "japanese": "",
    "korean": "明日までにレポートを出さなければなりません",
    "romaji": "あしたまでに れぽーとを ださなければ なりません",
    "english": "ashita made ni repōto o dasanakereba narimasen",
    "source": "아시타마데니 레포오토오 다사나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661418"
  },
  {
    "id": 481,
    "japanese": "",
    "korean": "会社に連絡しなければなりません",
    "romaji": "かいしゃに れんらく しなければ なりません",
    "english": "kaisha ni renraku shinakereba narimasen",
    "source": "카이샤니 렌라쿠 시나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661422"
  },
  {
    "id": 482,
    "japanese": "",
    "korean": "パスポートを持って行かなければなりません",
    "romaji": "ぱすぽーとを もって いかなければ なりません",
    "english": "pasupōto o motte ikanakereba narimasen",
    "source": "파스포오토오 못테 이카나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661427"
  },
  {
    "id": 483,
    "japanese": "",
    "korean": "野菜を食べなければなりません",
    "romaji": "やさいを たべなければ なりません",
    "english": "yasai o tabenakereba narimasen",
    "source": "야사이오 타베나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661431"
  },
  {
    "id": 484,
    "japanese": "",
    "korean": "電車に乗らなければなりません",
    "romaji": "でんしゃに のらなければ なりません",
    "english": "densha ni noranakereba narimasen",
    "source": "덴샤니 노라나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661434"
  },
  {
    "id": 485,
    "japanese": "",
    "korean": "時間を守らなければなりません",
