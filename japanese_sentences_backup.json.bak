  },
  {
    "id": 225,
    "japanese": "",
    "korean": "ヤンさんは仕事で遅れるそうです。",
    "romaji": "やんさんは しごとで おくれるそうです",
    "english": "yan san wa shigoto de okureru sō desu",
    "source": "얀상와 시고토데 오쿠레루소우데스",
    "added_date": "2026-04-26T03:06:31.659941"
  },
  {
    "id": 226,
    "japanese": "",
    "korean": "天気予報によると、明日は雨だそうです。",
    "romaji": "てんきよほうによると、あしたは あめだそうです",
    "english": "tenkiyohō ni yoru to, ashita wa ame da sō desu",
    "source": "텐키요호오니 요루토 아시타와 아메다소우데스",
    "added_date": "2026-04-26T03:06:31.659945"
  },
  {
    "id": 227,
    "japanese": "",
    "korean": "鈴木さんは来月韓国に行くそうです。",
    "romaji": "すずきさんは らいげつ かんこくに いくそうです",
    "english": "suzuki san wa raigetsu kankoku ni iku sō desu",
    "source": "스즈키상와 라이게츠 칸코쿠니 이쿠소우데스",
    "added_date": "2026-04-26T03:06:31.659949"
  },
  {
    "id": 228,
    "japanese": "",
    "korean": "使い方をちゃんと説明したそうです。",
    "romaji": "つかいかたを ちゃんと せつめいしたそうです",
    "english": "tsukaikata o chanto setsumei shita sō desu",
    "source": "츠카이카타오 찬토 세츠메이시타소우데스",
    "added_date": "2026-04-26T03:06:31.659953"
  },
