    "added_date": "2026-04-26T03:06:31.665374"
  },
  {
    "id": 1096,
    "japanese": "",
    "korean": "行けるかどうかよくわかりません",
    "romaji": "いけるかどうかよくわかりません",
    "english": "ikeru ka douka yoku wakarimasen",
    "source": "이케루카 도오카 요쿠 와카리마센",
    "added_date": "2026-04-26T03:06:31.665383"
  },
  {
    "id": 1097,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665388"
  },
  {
    "id": 1098,
    "japanese": "",
    "korean": "行けるかどうかよくわかりません",
    "romaji": "いけるかどうかよくわかりません",
    "english": "ikeru ka douka yoku wakarimasen",
    "source": "이케루카 도오카 요쿠 와카리마센",
    "added_date": "2026-04-26T03:06:31.665397"
  },
  {
    "id": 1099,
    "japanese": "2026-02-11",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665405"
  },
  {
    "id": 1100,
    "japanese": "",
    "korean": "先々週結婚式へ行きました。",
    "romaji": "せんせんしゅうけっこんしきへいきました",
    "english": "sensenshuu kekkonshiki e ikimashita",
    "source": "센센슈- 켁콘시키 에 이키마시타",
    "added_date": "2026-04-26T03:06:31.665414"
  },
  {
    "id": 1101,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665422"
  },
  {
    "id": 1102,
    "japanese": "",
    "korean": "会社の同僚たちが多かったんですね。",
    "romaji": "かいしゃのどうりょうたちがおおかったんですね",
    "english": "kaisha no douryou-tachi ga ookatta n desu ne",
    "source": "카이샤노 도-료-타치가 오-캇탄데스네",
    "added_date": "2026-04-26T03:06:31.665434"
  },
  {
    "id": 1103,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665444"
  },
  {
    "id": 1104,
    "japanese": "",
    "korean": "一度行ったことがあります。",
    "romaji": "いちどいったことがあります",
    "english": "ichido itta koto ga arimasu",
    "source": "이치도 잇타 코토가 아리마스",
    "added_date": "2026-04-26T03:06:31.665453"
  },
  {
    "id": 1105,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665461"
  },
  {
    "id": 1106,
    "japanese": "",
    "korean": "このバスは一日一回来ます。",
    "romaji": "このばすはいちにちいっかいきます",
    "english": "kono basu wa ichinichi ikkai kimasu",
    "source": "코노 바스와 이치니치 잇카이 키마스",
    "added_date": "2026-04-26T03:06:31.665469"
  },
  {
    "id": 1107,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665477"
  },
  {
    "id": 1108,
    "japanese": "",
    "korean": "どうぞ召し上がってください。",
    "romaji": "どうぞめしあがってください",
    "english": "douzo meshiagatte kudasai",
    "source": "도-조 메시아갓테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665485"
  },
  {
    "id": 1109,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665493"
  },
  {
    "id": 1110,
    "japanese": "",
    "korean": "お口に合うかどうかわかりませんが。",
    "romaji": "おくちにあうかどうかわかりませんが",
    "english": "okuchi ni au ka douka wakarimasen ga",
    "source": "오쿠치니 아우카 도-카 와카리마센가",
    "added_date": "2026-04-26T03:06:31.665501"
  },
  {
    "id": 1111,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665511"
  },
  {
    "id": 1112,
    "japanese": "",
    "korean": "家庭料理を一度食べてみたかったです。",
    "romaji": "かていりょうりをいちどたべてみたかったです",
    "english": "katei ryouri o ichido tabete mitakatta desu",
    "source": "카테이료-리오 이치도 타베테 미타캇타 데스",
    "added_date": "2026-04-26T03:06:31.665519"
  },
  {
    "id": 1113,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665527"
  },
  {
    "id": 1114,
    "japanese": "",
    "korean": "ごちそうさまでした。",
    "romaji": "ごちそうさまでした",
    "english": "gochisousama deshita",
    "source": "고치소-사마 데시타",
    "added_date": "2026-04-26T03:06:31.665535"
  },
  {
    "id": 1115,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665540"
  },
  {
    "id": 1116,
    "japanese": "",
    "korean": "テーブルの上に置いたまま食べます。",
    "romaji": "てーぶるのうえにおいたままたべます",
    "english": "teeburu no ue ni oita mama tabemasu",
    "source": "테-부루노 우에니 오이타 마마 타베마스",
    "added_date": "2026-04-26T03:06:31.665548"
  },
  {
    "id": 1117,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665556"
  },
  {
    "id": 1118,
    "japanese": "2026-02-12",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665564"
  },
  {
    "id": 1119,
    "japanese": "",
    "korean": "日本の焼き鳥を食べてみたいです。",
    "romaji": "にほんの やきとりを たべてみたいです",
    "english": "nihon no yakitori o tabete mitai desu",
    "source": "니혼노 야키토리오 타베테 미타이데스",
    "added_date": "2026-04-26T03:06:31.665573"
  },
  {
    "id": 1120,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665582"
  },
  {
    "id": 1121,
    "japanese": "",
    "korean": "ほとんど食べません。",
    "romaji": "ほとんど たべません",
    "english": "hotondo tabemasen",
    "source": "호톤도 타베마센",
    "added_date": "2026-04-26T03:06:31.665590"
  },
  {
    "id": 1122,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665599"
  },
  {
    "id": 1123,
    "japanese": "",
    "korean": "器を手に取って食べません。",
    "romaji": "うつわを てに とって たべません",
    "english": "utsuwa o te ni totte tabemasen",
    "source": "우츠와오 테니 톳테 타베마센",
    "added_date": "2026-04-26T03:06:31.665607"
  },
  {
    "id": 1124,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665615"
  },
  {
    "id": 1125,
    "japanese": "",
    "korean": "一本しか飲めません。",
    "romaji": "いっぽん しか のめません",
    "english": "ippon shika nomemasen",
    "source": "잇폰 시카 노메마센",
    "added_date": "2026-04-26T03:06:31.665624"
  },
  {
    "id": 1126,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665632"
  },
  {
    "id": 1127,
    "japanese": "",
    "korean": "二、三杯しか飲めないです。",
    "romaji": "にさんばい しか のめないです",
    "english": "nisanbai shika nomenai desu",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665640"
  },
  {
    "id": 1128,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665649"
  },
  {
    "id": 1129,
    "japanese": "",
    "korean": "ビールは四、五杯です。",
    "romaji": "びーるは よんごはい です",
    "english": "biiru wa yongo-hai desu",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665658"
  },
  {
    "id": 1130,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665666"
  },
  {
    "id": 1131,
    "japanese": "",
    "korean": "忙しくて電話をかけられません。",
    "romaji": "いそがしくて でんわを かけられません",
    "english": "isogashikute denwa o kakeraremasen",
    "source": "이소가시쿠테 덴와오 카케라레마센",
    "added_date": "2026-04-26T03:06:31.665676"
  },
  {
    "id": 1132,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665683"
  },
  {
    "id": 1133,
    "japanese": "",
    "korean": "高かったら買わないでください。",
    "romaji": "たかかったら かわないで ください",
    "english": "takakattara kawanai de kudasai",
    "source": "타카캇타라 카와나이데 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665689"
  },
  {
    "id": 1134,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665697"
  },
  {
    "id": 1135,
    "japanese": "26-02-23",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665705"
  },
  {
    "id": 1136,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665713"
  },
  {
    "id": 1137,
    "japanese": "",
    "korean": "月曜日にポハンへ行きます。",
    "romaji": "げつようびに ぽはん へ いきます。",
    "english": "getsuyōbi ni Pohang e ikimasu",
    "source": "게츠요-비니 포항에 이키마스",
    "added_date": "2026-04-26T03:06:31.665722"
  },
  {
    "id": 1138,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665729"
  },
  {
    "id": 1139,
    "japanese": "",
    "korean": "来週連休ですから早く食べなければなりません。",
    "romaji": "らいしゅう れんきゅう ですから はやく たべなければ なりません。",
    "english": "raishū renkyū desu kara hayaku tabenakereba narimasen",
    "source": "라이슈- 렌큐- 데스카라 하야쿠 타베나케레바 나리마셍",
    "added_date": "2026-04-26T03:06:31.665737"
  },
  {
    "id": 1140,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665746"
  },
  {
    "id": 1141,
    "japanese": "",
    "korean": "親に会ったほうがいいです。",
    "romaji": "おや に あった ほう が いい です。",
    "english": "oya ni atta hō ga ii desu",
    "source": "오야 니 앗타 호- 가 이이 데스",
    "added_date": "2026-04-26T03:06:31.665754"
  },
  {
    "id": 1142,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665762"
  },
  {
    "id": 1143,
    "japanese": "",
    "korean": "二、三杯しか飲めません。",
    "romaji": "に、さんばい しか のめません。",
    "english": "ni, sanbai shika nomemasen",
    "source": "니 산바이 시카 노메마셍",
    "added_date": "2026-04-26T03:06:31.665771"
  },
  {
    "id": 1144,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665779"
  },
  {
    "id": 1145,
    "japanese": "",
    "korean": "おかわりどうですか。",
    "romaji": "おかわり どう ですか。",
    "english": "okawari dō desu ka",
    "source": "오카와리 도- 데스카",
    "added_date": "2026-04-26T03:06:31.665787"
  },
  {
    "id": 1146,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665795"
  },
  {
    "id": 1147,
    "japanese": "",
    "korean": "おいしくて箸が止まらないです。",
    "romaji": "おいしくて はし が とまらない です。",
    "english": "oishikute hashi ga tomaranai desu",
    "source": "오이시쿠테 하시 가 토마라나이 데스",
    "added_date": "2026-04-26T03:06:31.665803"
  },
  {
    "id": 1148,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665811"
  },
  {
    "id": 1149,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665820"
  },
  {
    "id": 1150,
    "japanese": "",
    "korean": "忙しくてかけられないです。",
    "romaji": "いそがしくて かけられない です。",
    "english": "isogashikute kakerarenai desu",
    "source": "이소가시쿠테 카케라레나이 데스",
    "added_date": "2026-04-26T03:06:31.665831"
  },
  {
    "id": 1151,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665838"
  },
  {
    "id": 1152,
    "japanese": "",
    "korean": "おかわり自由",
    "romaji": "おかわり じゆう",
    "english": "okawari jiyū",
    "source": "오카와리 지유-",
    "added_date": "2026-04-26T03:06:31.665846"
  },
  {
    "id": 1153,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.665856"
  },
  {
    "id": 1154,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665869"
  },
  {
    "id": 1155,
    "japanese": "",
    "korean": "妹も結婚しました。",
    "romaji": "いもうと も けっこん しました",
    "english": "imōto mo kekkon shimashita",
    "source": "이모-토 모 켁콘 시마시타",
