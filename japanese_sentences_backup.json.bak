  {
    "id": 439,
    "japanese": "ほめる",
    "korean": "姉はいつも母に褒められます。",
    "romaji": "あね は いつも はは に ほめられます",
    "english": "ane wa itsumo haha ni homeraremasu",
    "source": "아네 와 이츠모 하하 니 호메라레마스",
    "added_date": "2026-04-26T03:06:31.661223"
  },
  {
    "id": 440,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661228"
  },
  {
    "id": 441,
    "japanese": "",
    "korean": "雨に降られる",
    "romaji": "あめ に ふられる",
    "english": "ame ni furareru",
    "source": "아메 니 후라레루",
    "added_date": "2026-04-26T03:06:31.661233"
  },
  {
    "id": 442,
    "japanese": "たてる",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661238"
  },
  {
    "id": 443,
    "japanese": "",
    "korean": "１０年前に建てられました",
    "romaji": "じゅうねん まえ に たてられました",
    "english": "jūnen mae ni tateraremashita",
    "source": "주우넨 마에 니 타테라레마시타",
    "added_date": "2026-04-26T03:06:31.661243"
  },
  {
    "id": 444,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661248"
  },
  {
    "id": 445,
    "japanese": "",
    "korean": "元彼女に来られて困りました",
    "romaji": "もとかのじょ に こられて こまりました",
    "english": "motokanojo ni korarete komarimashita",
    "source": "모토카노조 니 코라레테 코마리마시타",
    "added_date": "2026-04-26T03:06:31.661253"
  },
  {
    "id": 446,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661257"
  },
  {
    "id": 447,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661261"
  },
  {
    "id": 448,
    "japanese": "25-11-18",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661270"
  },
  {
    "id": 449,
    "japanese": "",
    "korean": "叱らないで褒めました",
    "romaji": "しからないで ほめました",
    "english": "shikaranaide homemashita",
    "source": "시카라나이데 호메마시타",
    "added_date": "2026-04-26T03:06:31.661275"
  },
  {
    "id": 450,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661280"
  },
  {
    "id": 451,
    "japanese": "",
    "korean": "1. 朝ごはんを食べないで出かけます。",
    "romaji": "あさごはんを たべないで でかけます",
    "english": "asagohan o tabenaide dekakemasu",
    "source": "아사가혼오 타베나이데 데카케마스",
    "added_date": "2026-04-26T03:06:31.661285"
  },
  {
    "id": 452,
    "japanese": "",
    "korean": "2. 傘を持たないで家を出ます。",
    "romaji": "かさを もたないで いえを でます",
    "english": "kasa o motanaide ie o demasu",
    "source": "카사오 모타나이데 이에오 데마스",
    "added_date": "2026-04-26T03:06:31.661290"
  },
  {
    "id": 453,
    "japanese": "",
    "korean": "3. 手を洗わないで料理します。",
    "romaji": "てを あらわないで りょうりします",
    "english": "te o arawanaide ryōri shimasu",
    "source": "테오 아라와나이데 료오리시마스",
    "added_date": "2026-04-26T03:06:31.661295"
  },
  {
    "id": 454,
    "japanese": "",
    "korean": "4. 読まないで提出します。",
    "romaji": "よまないで ていしゅつします",
    "english": "yomanaide teishutsu shimasu",
    "source": "요마나이데 테이슈츠시마스",
    "added_date": "2026-04-26T03:06:31.661300"
  },
  {
    "id": 455,
    "japanese": "",
    "korean": "5. 叱らないで話します。",
    "romaji": "しからないで はなします",
    "english": "shikaranaide hanashimasu",
    "source": "시카라나이데 하나시마스",
    "added_date": "2026-04-26T03:06:31.661305"
  },
  {
    "id": 456,
    "japanese": "",
    "korean": "6. 泳がないで見ています。",
    "romaji": "およがないで みています",
    "english": "oyoganaide mite imasu",
    "source": "오요가나이데 미테이마스",
    "added_date": "2026-04-26T03:06:31.661309"
  },
  {
    "id": 457,
    "japanese": "",
    "korean": "7. 休まないで働きます。",
    "romaji": "やすまないで はたらきます",
    "english": "yasumanaide hatarakimasu",
    "source": "야스마나이데 하타라키마스",
    "added_date": "2026-04-26T03:06:31.661315"
  },
  {
    "id": 458,
    "japanese": "",
    "korean": "8. 連絡しないで来ます。",
    "romaji": "れんらくしないで きます",
    "english": "renraku shinaide kimasu",
    "source": "렌라쿠 시나이데 키마스",
    "added_date": "2026-04-26T03:06:31.661322"
  },
  {
    "id": 459,
    "japanese": "",
    "korean": "9. 泣かないで話します。",
    "romaji": "なかないで はなします",
    "english": "nakanaide hanashimasu",
    "source": "나카나이데 하나시마스",
    "added_date": "2026-04-26T03:06:31.661327"
  },
  {
    "id": 460,
    "japanese": "",
    "korean": "10. 焦らないで進みます。",
    "romaji": "あせらないで すすみます",
    "english": "aseranaide susumimasu",
    "source": "아세라나이데 스스미마스",
    "added_date": "2026-04-26T03:06:31.661332"
  },
  {
    "id": 461,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
