  },
  {
    "id": 973,
    "japanese": "",
    "korean": "約束を守る",
    "romaji": "やくそくを まもる",
    "english": "yakusoku o mamoru",
    "source": "야쿠소쿠오 마모루",
    "added_date": "2026-04-26T03:06:31.664346"
  },
  {
    "id": 974,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664358"
  },
  {
    "id": 975,
    "japanese": "",
    "korean": "洗濯機を夜遅く回さないでほしいです。",
    "romaji": "せんたくきを よるおそく まわさないで ほしいです。",
    "english": "sentakuki o yoru osoku mawasanaide hoshii desu",
    "source": "센타쿠키오 요루 오소쿠 마와사나이데 호시이데스",
    "added_date": "2026-04-26T03:06:31.664370"
  },
  {
    "id": 976,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664379"
  },
  {
    "id": 977,
    "japanese": "",
    "korean": "かえらないでほしいです。",
    "romaji": "かえらないでほしいです。",
    "english": "kaeranai de hoshii desu",
    "source": "카에라나이데 호시이데스",
    "added_date": "2026-04-26T03:06:31.664387"
  },
  {
    "id": 978,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664396"
  },
  {
    "id": 979,
    "japanese": "",
    "korean": "日本語が上手になってほしいです",
    "romaji": "にほんごが じょうずに なって ほしいです",
    "english": "nihongo ga jouzu ni natte hoshii desu",
    "source": "니혼고가 조-즈니 낫테 호시이데스",
    "added_date": "2026-04-26T03:06:31.664405"
  },
  {
    "id": 980,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664413"
  },
  {
    "id": 981,
    "japanese": "",
    "korean": "背が高くなってほしいです",
    "romaji": "せが たかく なって ほしいです",
    "english": "se ga takaku natte hoshii desu",
    "source": "세가 타카쿠 낫테 호시이데스",
    "added_date": "2026-04-26T03:06:31.664421"
  },
  {
    "id": 982,
    "japanese": "",
    "korean": "구분",
    "romaji": "일본어",
    "english": "히라가나",
    "source": "로마자",
    "added_date": "2026-04-26T03:06:31.664429"
  },
  {
    "id": 983,
    "japanese": "",
    "korean": "현재 문장",
    "romaji": "一日しか会えないです。",
    "english": "いちにちしか あえないです",
    "source": "ichinichi shika aenai desu",
    "added_date": "2026-04-26T03:06:31.664437"
  },
  {
    "id": 984,
    "japanese": "",
    "korean": "더 자연스러운 표현",
    "romaji": "一日しか会えません。",
    "english": "いちにちしか あえません",
    "source": "ichinichi shika aemasen",
    "added_date": "2026-04-26T03:06:31.664445"
  },
  {
    "id": 985,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664453"
  },
  {
    "id": 986,
    "japanese": "",
    "korean": "たくさん使ってください",
    "romaji": "たくさん つかって ください",
    "english": "takusan tsukatte kudasai",
    "source": "타쿠상 츠캇테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.664461"
  },
  {
    "id": 987,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.664468"
  },
  {
    "id": 988,
    "japanese": "2026-01-20",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664477"
  },
  {
    "id": 989,
    "japanese": "",
    "korean": "最近はどんな本を読んでいますか。",
    "romaji": "さいきんはどんなほんをよんでいますか。",
    "english": "saikin wa donna hon o yonde imasu ka",
    "source": "사이킨와 돈나 혼오 욘데 이마스까",
    "added_date": "2026-04-26T03:06:31.664485"
  },
  {
    "id": 990,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664493"
  },
  {
    "id": 991,
    "japanese": "",
    "korean": "旅行の本を読んでいます。",
    "romaji": "りょこうのほんをよんでいます。",
    "english": "ryokō no hon o yonde imasu",
    "source": "료코-노 혼오 욘데 이마스",
    "added_date": "2026-04-26T03:06:31.664501"
  },
  {
    "id": 992,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664509"
  },
  {
    "id": 993,
    "japanese": "",
    "korean": "来週東京へ行きます。",
    "romaji": "らいしゅう とうきょうへ いきます。",
    "english": "raishū Tōkyō e ikimasu",
    "source": "라이슈- 도쿄에 이키마스",
    "added_date": "2026-04-26T03:06:31.664517"
  },
  {
    "id": 994,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664528"
  },
  {
    "id": 995,
    "japanese": "",
    "korean": "電気がついています。",
    "romaji": "でんきが ついています。",
    "english": "denki ga tsuite imasu",
    "source": "덴키가 츠이테 이마스",
    "added_date": "2026-04-26T03:06:31.664535"
  },
  {
    "id": 996,
    "japanese": "2026-01-21",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664544"
  },
  {
    "id": 997,
    "japanese": "",
    "korean": "夜中には洗濯機を回さないでほしいです",
    "romaji": "よなかには せんたくきを まわさないで ほしいです",
    "english": "yonaka ni wa sentakuki o mawasanaide hoshii desu",
    "source": "요나카니와 센타쿠키오 마와사나이데 호시이데스",
    "added_date": "2026-04-26T03:06:31.664551"
  },
  {
    "id": 998,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664559"
  },
  {
    "id": 999,
    "japanese": "",
    "korean": "電気がついている",
    "romaji": "でんきが ついている",
    "english": "denki ga tsuite iru",
    "source": "덴키가 츠이테 이루",
    "added_date": "2026-04-26T03:06:31.664567"
  },
  {
    "id": 1000,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664577"
  },
  {
    "id": 1001,
    "japanese": "",
    "korean": "３０センチを超えると粗大ゴミです。",
    "romaji": "さんじゅっセンチを こえると そだいごみです",
    "english": "sanju ssenchi o koeru to sodai gomi desu",
    "source": "산쥬 센치오 코에루토 소다이 고미데스",
    "added_date": "2026-04-26T03:06:31.664585"
  },
  {
    "id": 1002,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664594"
  },
  {
    "id": 1003,
    "japanese": "",
    "korean": "前回約束したのにまた忘れてしまいました",
    "romaji": "ぜんかい やくそくしたのに また わすれて しまいました",
    "english": "zenkai yakusoku shita noni mata wasurete shimaimashita",
    "source": "젠카이 야쿠소쿠 시타 노니 마타 와스레테 시마이마시타",
    "added_date": "2026-04-26T03:06:31.664601"
  },
  {
    "id": 1004,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664610"
  },
  {
    "id": 1005,
    "japanese": "",
    "korean": "窓を開けたまま寝てしまいました。",
    "romaji": "まどを あけたまま ねて しまいました",
    "english": "mado o aketa mama nete shimaimashita",
    "source": "마도오 아케타 마마 네테 시마이마시타",
    "added_date": "2026-04-26T03:06:31.664617"
  },
  {
    "id": 1006,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664625"
  },
  {
    "id": 1007,
    "japanese": "",
    "korean": "これからはルールを守ってほしいです",
    "romaji": "これからは るーるを まもって ほしいです",
    "english": "korekara wa rūru o mamotte hoshii desu",
    "source": "코레카라와 루우루오 마못테 호시이데스",
    "added_date": "2026-04-26T03:06:31.664633"
  },
  {
    "id": 1008,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664641"
  },
  {
    "id": 1009,
    "japanese": "",
    "korean": "ジブリ美術館に行くつもりです。",
    "romaji": "じぶりびじゅつかんに いく つもりです",
    "english": "jiburi bijutsukan ni iku tsumori desu",
    "source": "지부리 비쥬츠칸니 이쿠 츠모리데스",
    "added_date": "2026-04-26T03:06:31.664650"
  },
  {
    "id": 1010,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664658"
  },
  {
    "id": 1011,
    "japanese": "",
    "korean": "会ったら伝えてください。",
    "romaji": "あったら つたえて ください",
    "english": "attara tsutaete kudasai",
    "source": "앗따라 츠타에테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.664666"
  },
  {
    "id": 1012,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664674"
  },
  {
    "id": 1013,
    "japanese": "",
    "korean": "タクシーを拾ったら",
    "romaji": "たくしーを ひろったら",
    "english": "takushī o hirottara",
    "source": "타쿠시이오 히롯따라",
    "added_date": "2026-04-26T03:06:31.664682"
  },
  {
    "id": 1014,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664695"
  },
  {
    "id": 1015,
    "japanese": "",
    "korean": "明日キムさんが来るかどうか分かりません。",
    "romaji": "あした きむさんが くるかどうか わかりません",
    "english": "ashita kimu-san ga kuru ka dōka wakarimasen",
    "source": "아시타 키무상가 쿠루카 도우카 와카리마센",
    "added_date": "2026-04-26T03:06:31.664704"
  },
  {
    "id": 1016,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664713"
  },
  {
    "id": 1017,
    "japanese": "",
    "korean": "明日雨が降るかどうか分かりません。",
    "romaji": "あした あめが ふるかどうか わかりません",
    "english": "ashita ame ga furu ka dōka wakarimasen",
    "source": "아시타 아메가 후루카 도우카 와카리마센",
    "added_date": "2026-04-26T03:06:31.664721"
  },
  {
    "id": 1018,
    "japanese": "2026-01-30",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664729"
  },
  {
    "id": 1019,
    "japanese": "",
    "korean": "タクシーをひろいます",
    "romaji": "たくしーをひろいます",
    "english": "takushii o hiroimasu",
    "source": "타쿠시 오 히로이마스",
    "added_date": "2026-04-26T03:06:31.664737"
  },
  {
    "id": 1020,
    "japanese": "",
    "korean": "タクシーをひろいたいです",
    "romaji": "たくしーをひろいたいです",
    "english": "takushii o hiroitai desu",
    "source": "타쿠시 오 히로이타이 데스",
    "added_date": "2026-04-26T03:06:31.664745"
  },
  {
    "id": 1021,
    "japanese": "",
    "korean": "ここでタクシーをひろえますか",
    "romaji": "ここでたくしーをひろえますか",
    "english": "koko de takushii o hiroemasu ka",
    "source": "코코데 타쿠시 오 히로에마스까",
    "added_date": "2026-04-26T03:06:31.664754"
  },
  {
    "id": 1022,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.664762"
  },
  {
    "id": 1023,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664770"
  },
  {
    "id": 1024,
    "japanese": "",
    "korean": "東京へ行ったら何をするつもりですか",
    "romaji": "とうきょうへいったら なにをするつもりですか",
    "english": "tōkyō e ittara nani o suru tsumori desu ka",
    "source": "도쿄에 잇타라 나니오 스루 츠모리데스까",
    "added_date": "2026-04-26T03:06:31.664778"
  },
  {
    "id": 1025,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664786"
  },
  {
    "id": 1026,
    "japanese": "",
    "korean": "ジブリ美術館へ行くつもりです",
    "romaji": "じぶりびじゅつかんへ いくつもりです",
    "english": "jiburi bijutsukan e iku tsumori desu",
    "source": "지부리 비쥬츠칸에 이쿠 츠모리데스",
    "added_date": "2026-04-26T03:06:31.664794"
  },
  {
    "id": 1027,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664802"
  },
  {
    "id": 1028,
    "japanese": "",
    "korean": "あったら伝えてください。",
    "romaji": "あったら つたえてください",
    "english": "attara tsutaete kudasai",
    "source": "앗타라 츠타에테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.664810"
  },
  {
    "id": 1029,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664818"
  },
  {
    "id": 1030,
    "japanese": "",
    "korean": "きれいだし、背も高いし、性格もいいです。",
    "romaji": "きれいだし、せもたかいし、せいかくもいいです",
    "english": "kirei dashi se mo takai shi seikaku mo ii desu",
    "source": "키레이 다시 세모 타카이 시 세이카쿠모 이이데스",
    "added_date": "2026-04-26T03:06:31.664828"
  },
  {
    "id": 1031,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664833"
  },
  {
    "id": 1032,
    "japanese": "",
    "korean": "キムさんが来るかどうかわかりません。",
    "romaji": "きむさんがくるかどうかわかりません",
    "english": "kimu-san ga kuru ka dōka wakarimasen",
    "source": "키무상가 쿠루카 도-카 와카리마센",
    "added_date": "2026-04-26T03:06:31.664839"
  },
  {
    "id": 1033,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664849"
  },
  {
    "id": 1034,
    "japanese": "",
    "korean": "雨が降るかどうかわかりません。",
    "romaji": "あめがふるかどうかわかりません",
    "english": "ame ga furu ka dōka wakarimasen",
    "source": "아메가 후루카 도-카 와카리마센",
    "added_date": "2026-04-26T03:06:31.664859"
  },
  {
    "id": 1035,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664872"
  },
  {
    "id": 1036,
    "japanese": "",
    "korean": "明日カフェに行くつもりです。",
    "romaji": "あした かふぇに いくつもりです",
    "english": "ashita kafe ni iku tsumori desu",
    "source": "아시타 카페니 이쿠 츠모리데스",
    "added_date": "2026-04-26T03:06:31.664881"
  },
  {
    "id": 1037,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664889"
  },
  {
    "id": 1038,
    "japanese": "",
    "korean": "そつぎょうしたら",
    "romaji": "そつぎょうしたら",
    "english": "sotsugyō shitara",
    "source": "소츠교- 시타라",
    "added_date": "2026-04-26T03:06:31.664898"
  },
  {
    "id": 1039,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664906"
  },
  {
    "id": 1040,
    "japanese": "",
    "korean": "おじゃまします。",
    "romaji": "おじゃまします",
    "english": "ojama shimasu",
    "source": "오자마시마스",
    "added_date": "2026-04-26T03:06:31.664914"
  },
  {
    "id": 1041,
    "japanese": "",
    "korean": "お口に合うかどうかわかりませんが。",
    "romaji": "おくちにあうかどうかわかりませんが",
    "english": "okuchi ni au ka dōka wakarimasen ga",
    "source": "오쿠치니 아우카 도-카 와카리마센가",
    "added_date": "2026-04-26T03:06:31.664923"
  },
  {
    "id": 1042,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664931"
  },
  {
    "id": 1043,
    "japanese": "",
    "korean": "おうちがきれいだし広いし、いいです。",
    "romaji": "おうちがきれいだし ひろいし、いいです",
    "english": "ouchi ga kirei dashi hiroi shi ii desu",
    "source": "오우치가 키레이 다시 히로이 시 이이데스",
    "added_date": "2026-04-26T03:06:31.664939"
  },
  {
    "id": 1044,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664948"
  },
  {
    "id": 1045,
    "japanese": "",
    "korean": "おすすめのすしを聞いて食べました。",
    "romaji": "おすすめのすしをきいて たべました",
    "english": "osusume no sushi o kiite tabemashita",
    "source": "오스스메노 스시 오 키이테 타베마시타",
    "added_date": "2026-04-26T03:06:31.664956"
  },
  {
    "id": 1046,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664964"
  },
  {
    "id": 1047,
    "japanese": "",
    "korean": "スシ屋で",
    "romaji": "すしやで",
    "english": "sushi-ya de",
    "source": "스시야 데",
    "added_date": "2026-04-26T03:06:31.664972"
  },
  {
    "id": 1048,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664980"
  },
  {
    "id": 1049,
    "japanese": "",
    "korean": "お口に合うかどうかわかりませんが、どうぞ。",
    "romaji": "おくちにあうかどうかわかりませんが どうぞ",
    "english": "okuchi ni au ka dōka wakarimasen ga dōzo",
    "source": "오쿠치니 아우카 도-카 와카리마센가 도-조",
    "added_date": "2026-04-26T03:06:31.664986"
  },
  {
    "id": 1050,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.664995"
  },
  {
    "id": 1051,
    "japanese": "",
    "korean": "召し上がる",
    "romaji": "めしあがる",
    "english": "meshiagaru",
    "source": "메시아가루",
    "added_date": "2026-04-26T03:06:31.665006"
  },
  {
    "id": 1052,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665015"
  },
  {
    "id": 1053,
    "japanese": "",
    "korean": "召し上がってください。",
    "romaji": "めしあがってください",
    "english": "meshiagatte kudasai",
    "source": "메시아갓테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665025"
  },
  {
    "id": 1054,
    "japanese": "",
    "korean": "한국어",
    "romaji": "일본어",
    "english": "ひらがな",
    "source": "로마자",
    "added_date": "2026-04-26T03:06:31.665034"
  },
  {
    "id": 1055,
    "japanese": "",
    "korean": "일식",
    "romaji": "和食",
    "english": "わしょく",
    "source": "washoku",
    "added_date": "2026-04-26T03:06:31.665043"
  },
  {
    "id": 1056,
    "japanese": "",
    "korean": "일식집",
    "romaji": "和食屋",
    "english": "わしょくや",
    "source": "washoku-ya",
    "added_date": "2026-04-26T03:06:31.665051"
  },
  {
    "id": 1057,
    "japanese": "",
    "korean": "일본 요리",
    "romaji": "日本料理",
    "english": "にほんりょうり",
    "source": "nihon ryōri",
    "added_date": "2026-04-26T03:06:31.665059"
  },
  {
    "id": 1058,
    "japanese": "",
    "korean": "일식(요리 장르)",
    "romaji": "和風料理",
    "english": "わふうりょうり",
    "source": "wafū ryōri",
    "added_date": "2026-04-26T03:06:31.665067"
  },
  {
    "id": 1059,
    "japanese": "2026-02-04",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665073"
  },
  {
    "id": 1060,
    "japanese": "",
    "korean": "洗濯機を回したり掃除をしたり家事をしました。",
    "romaji": "せんたくきを まわしたり そうじを したり かじを しました。",
    "english": "sentakuki o mawashitari sōji o shitari kaji o shimashita",
    "source": "센타쿠키오 마와시타리 소오지오 시타리 카지오 시마시타",
    "added_date": "2026-04-26T03:06:31.665078"
  },
  {
    "id": 1061,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665084"
  },
  {
    "id": 1062,
    "japanese": "",
    "korean": "あがってください。",
    "romaji": "あがってください。",
    "english": "agatte kudasai",
    "source": "아갓테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665091"
  },
  {
    "id": 1063,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665096"
  },
  {
    "id": 1064,
    "japanese": "",
    "korean": "お口にあうかどうかわかりませんが、どうぞ召し上がってください。",
    "romaji": "おくちに あうか どうか わかりませんが、どうぞ めしあがって ください。",
    "english": "okuchi ni au ka dōka wakarimasen ga, dōzo meshiagatte kudasai",
    "source": "오쿠치니 아우카 도오카 와카리마센가 도오조 메시아갓테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665106"
  },
  {
    "id": 1065,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665116"
  },
  {
    "id": 1066,
    "japanese": "",
    "korean": "和室",
    "romaji": "わしつ",
    "english": "washitsu",
    "source": "와시츠",
    "added_date": "2026-04-26T03:06:31.665125"
  },
  {
    "id": 1067,
    "japanese": "",
    "korean": "和食",
    "romaji": "わしょく",
    "english": "washoku",
    "source": "와쇼쿠",
    "added_date": "2026-04-26T03:06:31.665132"
  },
  {
    "id": 1068,
    "japanese": "",
    "korean": "和牛",
    "romaji": "わぎゅう",
    "english": "wagyū",
    "source": "와규",
    "added_date": "2026-04-26T03:06:31.665140"
  },
  {
    "id": 1069,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665149"
  },
  {
    "id": 1070,
    "japanese": "",
    "korean": "お庭もきれいだし、リビングも広いし、素敵なおうちですね。",
    "romaji": "おにわも きれいだし、りびんぐも ひろいし、すてきな おうちですね。",
    "english": "oni wa mo kirei dashi, ribingu mo hiroi shi, suteki na ouchi desu ne",
    "source": "오니와모 키레이 다시 리빙구모 히로이시 스테키나 오우치데스네",
    "added_date": "2026-04-26T03:06:31.665157"
  },
  {
    "id": 1071,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665165"
  },
  {
    "id": 1072,
    "japanese": "",
    "korean": "少し狭いので、娘が小学校を卒業したら引っ越すつもりです。",
    "romaji": "すこし せまいので、むすめが しょうがっこうを そつぎょうしたら ひっこす つもりです。",
    "english": "sukoshi semai node, musume ga shōgakkō o sotsugyō shitara hikkosu tsumori desu",
    "source": "스코시 세마이노데 무스메가 쇼오각코오오 소츠교오시타라 힛코스 츠모리데스",
    "added_date": "2026-04-26T03:06:31.665179"
  },
  {
    "id": 1073,
    "japanese": "2026-02-05",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665185"
  },
  {
    "id": 1074,
    "japanese": "",
    "korean": "五時半に帰ってきました。",
    "romaji": "ごじはんにかえってきました",
    "english": "goji-han ni kaette kimashita",
    "source": "고지한 니 카엣테 키마시타",
    "added_date": "2026-04-26T03:06:31.665191"
  },
  {
    "id": 1075,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665198"
  },
  {
    "id": 1076,
    "japanese": "",
    "korean": "いらっしゃい。",
    "romaji": "いらっしゃい",
    "english": "irasshai",
    "source": "이랏샤이",
    "added_date": "2026-04-26T03:06:31.665207"
  },
  {
    "id": 1077,
    "japanese": "",
    "korean": "どうぞ、上がってください。",
    "romaji": "どうぞ、あがってください",
    "english": "dōzo, agatte kudasai",
    "source": "도오조 아갓테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.665216"
  },
  {
    "id": 1078,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665225"
  },
  {
    "id": 1079,
    "japanese": "",
    "korean": "お邪魔します。",
    "romaji": "おじゃまします",
    "english": "ojama shimasu",
    "source": "오자마 시마스",
    "added_date": "2026-04-26T03:06:31.665233"
  },
  {
    "id": 1080,
    "japanese": "",
    "korean": "これ、韓国のノリです。",
    "romaji": "これ、かんこくののりです",
    "english": "kore, kankoku no nori desu",
    "source": "코레 칸코쿠 노 노리 데스",
    "added_date": "2026-04-26T03:06:31.665242"
  },
  {
    "id": 1081,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665251"
  },
  {
    "id": 1082,
    "japanese": "",
    "korean": "一緒に行くといいですが。",
    "romaji": "いっしょにいくといいですが",
    "english": "issho ni iku to ii desu ga",
    "source": "잇쇼니 이쿠 토 이이데스가",
    "added_date": "2026-04-26T03:06:31.665260"
  },
  {
    "id": 1083,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665268"
  },
  {
    "id": 1084,
    "japanese": "",
    "korean": "忙しくもないし、仕事も多くないし。",
    "romaji": "いそがしくもないし、しごとも おおくないし",
    "english": "isogashiku mo nai shi shigoto mo ōku nai shi",
    "source": "이소가시쿠모 나이시 시고토모 오오쿠 나이시",
    "added_date": "2026-04-26T03:06:31.665276"
  },
  {
    "id": 1085,
    "japanese": "2026-02-10",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665286"
  },
  {
    "id": 1086,
    "japanese": "",
    "korean": "お茶を入れてきますので",
    "romaji": "おちゃをいれてきますので",
    "english": "ocha o irete kimasu node",
    "source": "오차오 이레테 키마스 노데",
    "added_date": "2026-04-26T03:06:31.665295"
  },
  {
    "id": 1087,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665304"
  },
  {
    "id": 1088,
    "japanese": "",
    "korean": "お庭もきれいだし、リビングも広いし、素敵なおうちですね。",
    "romaji": "おにわもきれいだし、りびんぐもひろいし、すてきなおうちですね。",
    "english": "oniwa mo kirei da shi ribingu mo hiroi shi suteki na ouchi desu ne",
    "source": "오니와모 키레이 다시 리빙구모 히로이 시 스테키나 오우치데스네",
    "added_date": "2026-04-26T03:06:31.665312"
  },
  {
    "id": 1089,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665321"
  },
  {
    "id": 1090,
    "japanese": "",
    "korean": "忙しくないし、仕事も多くないし",
    "romaji": "いそがしくないし、しごともおおくないし",
    "english": "isogashikunai shi shigoto mo ookunai shi",
    "source": "이소가시쿠 나이 시 시고토모 오오쿠 나이 시",
    "added_date": "2026-04-26T03:06:31.665328"
  },
  {
    "id": 1091,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665337"
  },
  {
    "id": 1092,
    "japanese": "",
    "korean": "横",
    "romaji": "よこ",
    "english": "yoko",
    "source": "요코",
