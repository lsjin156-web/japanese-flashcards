  },
  {
    "id": 602,
    "japanese": "",
    "korean": "筋肉痛",
    "romaji": "きんにくつう",
    "english": "kinniku tsū",
    "source": "킨니쿠 츠우",
    "added_date": "2026-04-26T03:06:31.661984"
  },
  {
    "id": 603,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.661992"
  },
  {
    "id": 604,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662001"
  },
  {
    "id": 605,
    "japanese": "",
    "korean": "今日は早く帰ってぐっすり寝ました",
    "romaji": "きょうは はやく かえって ぐっすり ねました",
    "english": "kyō wa hayaku kaette gussuri nemashita",
    "source": "쿄오와 하야쿠 카엣테 굿스리 네마시타",
    "added_date": "2026-04-26T03:06:31.662004"
  },
  {
    "id": 606,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662008"
  },
  {
    "id": 607,
    "japanese": "",
    "korean": "そっちへ行くと道がせまくなるかもしれません",
    "romaji": "そっちへ いくと みちが せまくなる かもしれません",
    "english": "socchi e iku to michi ga semakunaru kamoshiremasen",
    "source": "솟치에 이쿠토 미치가 세마쿠나루 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662013"
  },
  {
    "id": 608,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.662019"
  },
  {
    "id": 609,
    "japanese": "2025-12-02",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662028"
  },
  {
    "id": 610,
    "japanese": "",
    "korean": "使い捨て用品",
    "romaji": "つかいすてようひん",
    "english": "tsukaisute yōhin",
    "source": "쓰카이스테 요오힌",
    "added_date": "2026-04-26T03:06:31.662034"
  },
  {
    "id": 611,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662039"
  },
  {
    "id": 612,
    "japanese": "",
    "korean": "寝不足",
    "romaji": "ねぶそく",
    "english": "nebusoku",
    "source": "네부소쿠",
    "added_date": "2026-04-26T03:06:31.662047"
  },
  {
    "id": 613,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662055"
  },
  {
    "id": 614,
    "japanese": "",
    "korean": "四時半に帰ってきて５時から７時まで寝て少し勉強しました。",
    "romaji": "よじはんに かえってきて ごじから しちじまで ねて すこし べんきょうしました",
    "english": "yojihan ni kaette kite goji kara shichiji made nete sukoshi benkyō shimashita",
    "source": "요지한니 카엣테키테 고지카라 시치지마데 네테 스코시 벤쿄오시마시타",
    "added_date": "2026-04-26T03:06:31.662063"
  },
  {
    "id": 615,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662069"
  },
  {
    "id": 616,
    "japanese": "",
    "korean": "まだ夕ご飯は食べていないです。",
    "romaji": "まだ ゆうごはんは たべていないです",
    "english": "mada yūgohan wa tabete inai desu",
    "source": "마다 유우고한와 타베테이나이데스",
    "added_date": "2026-04-26T03:06:31.662074"
  },
  {
    "id": 617,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.662078"
  },
  {
    "id": 618,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662082"
  },
  {
    "id": 619,
    "japanese": "",
    "korean": "風邪を引かないように気を付けてください。",
    "romaji": "かぜを ひかないように きをつけてください",
    "english": "kaze o hikanai yō ni ki o tsukete kudasai",
    "source": "카제오 히카나이요오니 키오츠케테쿠다사이",
    "added_date": "2026-04-26T03:06:31.662087"
  },
  {
    "id": 620,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
