  },
  {
    "id": 846,
    "japanese": "",
    "korean": "資源ごみ",
    "romaji": "しげんごみ",
    "english": "shigen gomi",
    "source": "시겐 고미",
    "added_date": "2026-04-26T03:06:31.663632"
  },
