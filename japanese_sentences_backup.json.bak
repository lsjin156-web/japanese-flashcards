  {
    "id": 1429,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667896"
  },
  {
    "id": 1430,
    "japanese": "",
    "korean": "たまにご飯は食べません",
    "romaji": "たまに ごはんは たべません",
    "english": "tamani gohan wa tabemasen",
    "source": "타마니 고항와 타베마센",
    "added_date": "2026-04-26T03:06:31.667900"
  },
  {
    "id": 1431,
    "japanese": "2026-04-01",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.667904"
  },
  {
    "id": 1432,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667908"
  },
  {
    "id": 1433,
    "japanese": "",
    "korean": "テレビが少し壊れたんです。",
    "romaji": "テレビ が すこし こわれた んです。",
    "english": "terebi ga sukoshi kowareta n desu",
    "source": "테레비가 스코시 코와레탄 데스",
    "added_date": "2026-04-26T03:06:31.667912"
  },
  {
    "id": 1434,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667915"
  },
  {
    "id": 1435,
    "japanese": "",
    "korean": "体に悪いところはありません。",
    "romaji": "からだ に わるい ところ は ありません。",
    "english": "karada ni warui tokoro wa arimasen",
    "source": "카라다 니 와루이 토코로와 아리마셍",
    "added_date": "2026-04-26T03:06:31.667920"
  },
  {
    "id": 1436,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667924"
  },
  {
    "id": 1437,
    "japanese": "",
    "korean": "妻は今忙しくて、まだ来ていません。",
    "romaji": "つま は いま いそがしくて、まだ きていません。",
    "english": "tsuma wa ima isogashikute, mada kiteimasen",
    "source": "츠마 와 이마 이소가시쿠테 마다 키테이마셍",
    "added_date": "2026-04-26T03:06:31.667927"
  },
  {
    "id": 1438,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667931"
  },
  {
    "id": 1439,
    "japanese": "",
    "korean": "三食は全部ご飯ですか。",
    "romaji": "さんしょく は ぜんぶ ごはん ですか。",
    "english": "sanshoku wa zenbu gohan desu ka",
    "source": "산쇼쿠 와 젠부 고한 데스카",
    "added_date": "2026-04-26T03:06:31.667935"
  },
  {
    "id": 1440,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667938"
  },
  {
    "id": 1441,
    "japanese": "",
    "korean": "昼ごはんだけご飯を食べます。",
    "romaji": "ひるごはん だけ ごはん を たべます。",
    "english": "hirugohan dake gohan o tabemasu",
    "source": "히루고한 다케 고한 오 타베마스",
    "added_date": "2026-04-26T03:06:31.667942"
  },
  {
    "id": 1442,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.667946"
  },
  {
    "id": 1443,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667953"
  },
  {
    "id": 1444,
    "japanese": "",
    "korean": "寒いので中へお入りください。",
    "romaji": "さむい ので なか へ おはいり ください。",
    "english": "samui node naka e ohairi kudasai",
    "source": "사무이 노데 나카 에 오하이리 쿠다사이",
    "added_date": "2026-04-26T03:06:31.667956"
  },
  {
    "id": 1445,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.667960"
  },
  {
    "id": 1446,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667966"
  },
  {
    "id": 1447,
    "japanese": "",
    "korean": "今日は忙しくなかったので、早く帰りました。",
    "romaji": "きょう は いそがしく なかった ので、はやく かえりました。",
    "english": "kyou wa isogashiku nakatta node, hayaku kaerimashita",
    "source": "쿄-와 이소가시쿠 나캇타 노데 하야쿠 카에리마시타",
    "added_date": "2026-04-26T03:06:31.667970"
  },
  {
    "id": 1448,
