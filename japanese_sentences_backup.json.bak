  },
  {
    "id": 54,
    "japanese": "",
    "korean": "おいしい食堂があるそうですね",
    "romaji": "おいしい しょくどう が あるそうですね",
    "english": "oishii shokudou ga arusou desu ne",
    "source": "오이시이 쇼쿠도우 가 아루소우데스네",
