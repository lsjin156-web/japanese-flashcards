    "korean": "超える",
    "romaji": "こえる",
    "english": "koeru",
    "source": "코에루",
    "added_date": "2026-04-26T03:06:31.663652"
  },
  {
    "id": 851,
    "japanese": "",
    "korean": "燃えるゴミ",
    "romaji": "もえるごみ",
    "english": "moeru gomi",
    "source": "모에루 고미",
    "added_date": "2026-04-26T03:06:31.663656"
  },
  {
    "id": 852,
    "japanese": "",
    "korean": "燃えないゴミ",
    "romaji": "もえないごみ",
    "english": "moenai gomi",
    "source": "모에나이 고미",
    "added_date": "2026-04-26T03:06:31.663660"
  },
  {
    "id": 853,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663664"
  },
  {
    "id": 854,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663669"
  },
  {
    "id": 855,
    "japanese": "",
    "korean": "３０センチを超えると有料です。",
    "romaji": "さんじゅっセンチを こえると ゆうりょうです。",
    "english": "sanjussentchi o koeru to yūryō desu",
    "source": "산줏센치오 코에루토 유-료데스",
    "added_date": "2026-04-26T03:06:31.663673"
  },
  {
    "id": 856,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663677"
  },
  {
    "id": 857,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663681"
  },
  {
    "id": 858,
    "japanese": "",
    "korean": "ゴミは九時を過ぎると出せません。",
    "romaji": "ごみは くじを すぎると だせません。",
    "english": "gomi wa kuji o sugiru to dasemasen",
    "source": "고미와 쿠지오 스기루토 다세마센",
    "added_date": "2026-04-26T03:06:31.663688"
  },
  {
    "id": 859,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663693"
  },
  {
    "id": 860,
    "japanese": "",
    "korean": "ゴミ袋にいれて出してください。",
    "romaji": "ごみぶくろに いれて だしてください。",
    "english": "gomibukuro ni irete dashite kudasai",
    "source": "고미부쿠로니 이레테 다시테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.663697"
  },
  {
    "id": 861,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663701"
  },
  {
    "id": 862,
    "japanese": "",
    "korean": "クレジットカードしか持てないです。",
    "romaji": "くれじっとかーど しか もてない です。",
    "english": "kurejitto kādo shika motenai desu",
    "source": "크레짓토 카도 시카 모테나이데스",
    "added_date": "2026-04-26T03:06:31.663709"
  },
  {
    "id": 863,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663713"
  },
  {
    "id": 864,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663717"
  },
  {
    "id": 865,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663721"
  },
  {
    "id": 866,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663725"
  },
  {
    "id": 867,
    "japanese": "",
    "korean": "まだ働けるのに、辞めるんです。",
    "romaji": "まだ はたらける のに、やめる んです。",
    "english": "mada hatarakeru noni, yameru n desu",
    "source": "마다 하타라케루 노니 야메룬데스",
    "added_date": "2026-04-26T03:06:31.663729"
  },
  {
    "id": 868,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663734"
  },
  {
    "id": 869,
    "japanese": "",
    "korean": "まだ会えるのに、別れるんです。",
    "romaji": "まだ あえる のに、わかれる んです。",
    "english": "mada aeru noni, wakareru n desu",
    "source": "마다 아에루 노니 와카레룬데스",
    "added_date": "2026-04-26T03:06:31.663738"
  },
  {
    "id": 870,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663742"
  },
  {
    "id": 871,
    "japanese": "",
    "korean": "まだ使えるのに、捨てるんですか。",
    "romaji": "まだ つかえる のに、すてる んですか。",
    "english": "mada tsukaeru noni, suteru n desu ka",
    "source": "마다 츠카에루 노니 스테룬데스까",
    "added_date": "2026-04-26T03:06:31.663746"
  },
  {
    "id": 872,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663751"
  },
  {
    "id": 873,
    "japanese": "2025-01-05",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663755"
  },
  {
    "id": 874,
    "japanese": "",
    "korean": "ビンも燃えないゴミですか。",
    "romaji": "びんも もえない ごみ ですか。",
    "english": "bin mo moenai gomi desu ka",
    "source": "빈모 모에나이 고미 데스까",
    "added_date": "2026-04-26T03:06:31.663759"
  },
  {
    "id": 875,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663763"
  },
  {
    "id": 876,
    "japanese": "",
    "korean": "ゴミじゃなくて資源ゴミです。",
    "romaji": "ごみじゃなくて しげんごみ です。",
    "english": "gomi ja nakute shigen gomi desu",
    "source": "고미 자 나쿠테 시겐고미 데스",
    "added_date": "2026-04-26T03:06:31.663767"
  },
  {
    "id": 877,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663774"
  },
  {
    "id": 878,
    "japanese": "",
    "korean": "鞄も捨てたいんですが。",
    "romaji": "かばんも すてたいんですが。",
    "english": "kaban mo sutetain desu ga",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663778"
  },
  {
    "id": 879,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663782"
  },
  {
    "id": 880,
    "japanese": "",
    "korean": "まだ、働けるのにやめるんですか。",
    "romaji": "まだ、はたらける のに やめるんですか。",
    "english": "mada hatarakeru noni yamerun desu ka",
    "source": "마다 하타라케루 노니 야메룬 데스까",
    "added_date": "2026-04-26T03:06:31.663787"
  },
  {
    "id": 881,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663791"
  },
  {
    "id": 882,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663795"
  },
  {
    "id": 883,
    "japanese": "",
    "korean": "他人に迷惑をかける",
    "romaji": "たにんに めいわくを かける",
    "english": "tanin ni meiwaku o kakeru",
    "source": "타닌니 메이와쿠오 카케루",
    "added_date": "2026-04-26T03:06:31.663799"
  },
  {
    "id": 884,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663803"
  },
  {
    "id": 885,
    "japanese": "",
    "korean": "服を着たまま寝ました。",
    "romaji": "ふくを きたまま ねました。",
    "english": "fuku o kita mama nemashita",
    "source": "후쿠오 키타 마마 네마시타",
    "added_date": "2026-04-26T03:06:31.663808"
  },
  {
    "id": 886,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663812"
  },
  {
    "id": 887,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663816"
  },
  {
    "id": 888,
    "japanese": "2025-01-08",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663821"
  },
  {
    "id": 889,
    "japanese": "",
    "korean": "ちょっといいですか。",
    "romaji": "ちょっと いいですか",
    "english": "chotto ii desu ka",
    "source": "춋또 이이데스카",
    "added_date": "2026-04-26T03:06:31.663825"
  },
  {
    "id": 890,
    "japanese": "",
    "korean": "相談したいことがあります。",
    "romaji": "そうだん したい ことが あります",
    "english": "sōdan shitai koto ga arimasu",
    "source": "소오단 시타이 코토가 아리마스",
    "added_date": "2026-04-26T03:06:31.663829"
  },
  {
    "id": 891,
    "japanese": "",
    "korean": "ちょっといいですか。相談したいことがあります。",
    "romaji": "ちょっと いいですか。そうだん したい ことが あります",
    "english": "chotto ii desu ka sōdan shitai koto ga arimasu",
    "source": "춋또 이이데스카 소오단 시타이 코토가 아리마스",
    "added_date": "2026-04-26T03:06:31.663833"
  },
  {
    "id": 892,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663837"
  },
  {
    "id": 893,
    "japanese": "",
    "korean": "会社の同僚とよく相談します。",
    "romaji": "かいしゃ の どうりょう と よく そうだん します",
    "english": "kaisha no dōryō to yoku sōdan shimasu",
    "source": "카이샤 노 도오료오 또 요쿠 소오단 시마스",
    "added_date": "2026-04-26T03:06:31.663841"
  },
  {
    "id": 894,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663846"
  },
  {
    "id": 895,
    "japanese": "",
    "korean": "隣の人とよく相談します。",
    "romaji": "となり の ひと と よく そうだん します",
    "english": "tonari no hito to yoku sōdan shimasu",
    "source": "토나리 노 히토 또 요쿠 소오단 시마스",
    "added_date": "2026-04-26T03:06:31.663850"
  },
  {
    "id": 896,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663854"
  },
  {
    "id": 897,
    "japanese": "",
    "korean": "会社では同僚とよく相談します。",
    "romaji": "かいしゃ では どうりょう と よく そうだん します",
    "english": "kaisha dewa dōryō to yoku sōdan shimasu",
    "source": "카이샤 데와 도오료오 또 요쿠 소오단 시마스",
    "added_date": "2026-04-26T03:06:31.663862"
  },
  {
    "id": 898,
    "japanese": "",
    "korean": "周りの人とよく相談します。",
    "romaji": "まわり の ひと と よく そうだん します",
    "english": "mawari no hito to yoku sōdan shimasu",
    "source": "마와리 노 히토 또 요쿠 소오단 시마스",
    "added_date": "2026-04-26T03:06:31.663877"
  },
  {
    "id": 899,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663886"
  },
  {
    "id": 900,
    "japanese": "",
    "korean": "服を着たまま寝ました。",
    "romaji": "ふく を きた まま ねました",
    "english": "fuku o kita mama nemashita",
    "source": "후쿠오 키타 마마 네마시타",
    "added_date": "2026-04-26T03:06:31.663895"
  },
  {
    "id": 901,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663901"
  },
  {
    "id": 902,
    "japanese": "",
    "korean": "明けましておめでとうございます。",
    "romaji": "あけまして おめでとう ございます",
    "english": "akemashite omedetō gozaimasu",
    "source": "아케마시테 오메데토- 고자이마스",
    "added_date": "2026-04-26T03:06:31.663906"
  },
  {
