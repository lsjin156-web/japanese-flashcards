    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.667974"
  },
  {
    "id": 1449,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667982"
  },
  {
    "id": 1450,
    "japanese": "",
    "korean": "今週は忙しいです。",
    "romaji": "こんしゅう は いそがしい です。",
    "english": "konshuu wa isogashii desu",
    "source": "콘슈- 와 이소가시이 데스",
    "added_date": "2026-04-26T03:06:31.667989"
  },
  {
    "id": 1451,
    "japanese": "2026-04-24",
