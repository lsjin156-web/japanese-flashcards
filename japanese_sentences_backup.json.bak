  },
  {
    "id": 625,
    "japanese": "",
    "korean": "筋肉痛",
    "romaji": "きんにくつう",
    "english": "kinniku tsū",
    "source": "킨니쿠츠우",
    "added_date": "2026-04-26T03:06:31.662118"
  },
  {
    "id": 626,
    "japanese": "",
    "korean": "頭痛",
    "romaji": "ずつう",
    "english": "zutsū",
    "source": "즈츠우",
    "added_date": "2026-04-26T03:06:31.662123"
  },
  {
    "id": 627,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "ローマ字",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662128"
  },
  {
    "id": 628,
    "japanese": "",
    "korean": "おふろにはいる",
    "romaji": "おふろに はいる",
    "english": "ofuro ni hairu",
    "source": "오후로니 하이루",
    "added_date": "2026-04-26T03:06:31.662132"
  },
  {
    "id": 629,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662137"
  },
  {
    "id": 630,
    "japanese": "",
    "korean": "昨日は早く帰ってぐっすり寝ました。",
    "romaji": "きのうは はやく かえって ぐっすり ねました",
    "english": "kinō wa hayaku kaette gussuri nemashita",
    "source": "기노우와 하야쿠 카엣테 굿스리 네마시타",
    "added_date": "2026-04-26T03:06:31.662142"
  },
  {
    "id": 631,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662151"
  },
  {
    "id": 632,
    "japanese": "",
    "korean": "飲むと少し眠くなるかもしれません。",
    "romaji": "のむと すこし ねむくなる かもしれません",
    "english": "nomu to sukoshi nemuku naru kamoshiremasen",
    "source": "노무토 스코시 네무쿠나루 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662160"
  },
  {
    "id": 633,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.662166"
  },
  {
    "id": 634,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662174"
  },
  {
    "id": 635,
    "japanese": "",
    "korean": "今日は雨が降るかもしれません。",
    "romaji": "きょうは あめが ふる かもしれません",
    "english": "kyō wa ame ga furu kamoshiremasen",
    "source": "쿄오와 아메가 후루 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662180"
  },
  {
    "id": 636,
    "japanese": "",
    "korean": "彼は遅れるかもしれません。",
    "romaji": "かれは おくれる かもしれません",
    "english": "kare wa okureru kamoshiremasen",
    "source": "카레와 오쿠레루 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662188"
  },
  {
    "id": 637,
    "japanese": "",
    "korean": "明日は寒いかもしれません。",
    "romaji": "あしたは さむい かもしれません",
    "english": "ashita wa samui kamoshiremasen",
    "source": "아시타와 사무이 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662195"
  },
  {
    "id": 638,
    "japanese": "",
    "korean": "この薬は眠くなるかもしれません。",
    "romaji": "このくすりは ねむくなる かもしれません",
    "english": "kono kusuri wa nemuku naru kamoshiremasen",
    "source": "코노 쿠스리와 네무쿠나루 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662201"
  },
  {
    "id": 639,
    "japanese": "",
    "korean": "そこは静かかもしれません。",
    "romaji": "そこは しずか かもしれません",
    "english": "soko wa shizuka kamoshiremasen",
    "source": "소코와 시즈카 카모시레마센",
    "added_date": "2026-04-26T03:06:31.662209"
  },
  {
    "id": 640,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662217"
  },
  {
    "id": 641,
    "japanese": "",
    "korean": "いつ行けばいいですか",
    "romaji": "いつ いけば いい です か",
    "english": "itsu ikeba ii desu ka",
    "source": "이츠 이케바 이이 데스카",
    "added_date": "2026-04-26T03:06:31.662225"
  },
  {
    "id": 642,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662233"
  },
  {
    "id": 643,
    "japanese": "",
    "korean": "いつ作ればいいですか",
    "romaji": "いつ つくれば いい です か",
    "english": "itsu tsukureba ii desu ka",
    "source": "이츠 츠쿠레바 이이 데스카",
    "added_date": "2026-04-26T03:06:31.662247"
  },
  {
    "id": 644,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらが나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662253"
  },
  {
    "id": 645,
    "japanese": "",
    "korean": "いつ待てばいいですか",
    "romaji": "いつ まてば いい です か",
    "english": "itsu mateba ii desu ka",
    "source": "이츠 마테바 이이 데스카",
    "added_date": "2026-04-26T03:06:31.662259"
  },
  {
    "id": 646,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.662267"
  },
  {
    "id": 647,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.662273"
  },
  {
    "id": 648,
    "japanese": "",
    "korean": "待たないで先に行ってください",
    "romaji": "またないで さきに いって ください",
    "english": "matanaide sakini itte kudasai",
    "source": "마타나이데 사키니 잇테 쿠다사이",
    "added_date": "2026-04-26T03:06:31.662279"
  },
  {
    "id": 649,
