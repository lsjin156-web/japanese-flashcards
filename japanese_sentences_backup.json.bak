    "added_date": "2026-04-26T03:06:31.659773"
  },
  {
    "id": 193,
    "japanese": "",
    "korean": "コーヒーを飲もうと思います。",
    "romaji": "コーヒーを のもうと おもいます。",
    "english": "kōhī o nomō to omoimasu",
