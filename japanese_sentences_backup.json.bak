    "added_date": "2026-04-26T03:06:31.667532"
  },
  {
    "id": 1353,
    "japanese": "",
    "korean": "一緒に会うつもりです",
    "romaji": "いっしょにあうつもりです",
    "english": "issho ni au tsumori desu",
    "source": "잇쇼니 아우 츠모리 데스",
    "added_date": "2026-04-26T03:06:31.667537"
  },
  {
    "id": 1354,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667542"
  },
  {
    "id": 1355,
    "japanese": "",
    "korean": "妹の誕生日なのでたぶん家族と一緒に食事会がある予定です",
    "romaji": "いもうとのたんじょうびなのでたぶんかぞくといっしょにしょくじかいがあるよていです",
    "english": "imouto no tanjoubi na node tabun kazoku to issho ni shokujikai ga aru yotei desu",
    "source": "이모토노 탄죠비 나노데 타분 카조쿠토 잇쇼니 쇼쿠지카이가 아루 요테이 데스",
    "added_date": "2026-04-26T03:06:31.667548"
  },
  {
    "id": 1356,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667554"
  },
  {
    "id": 1357,
    "japanese": "",
    "korean": "お持ちですか",
    "romaji": "おもちですか",
    "english": "omochi desu ka",
    "source": "오모치 데스까",
    "added_date": "2026-04-26T03:06:31.667564"
  },
  {
    "id": 1358,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667568"
  },
  {
    "id": 1359,
    "japanese": "",
    "korean": "お送りします",
    "romaji": "おおくりします",
    "english": "ookuri shimasu",
    "source": "오오쿠리 시마스",
    "added_date": "2026-04-26T03:06:31.667572"
  },
  {
    "id": 1360,
    "japanese": "",
    "korean": "お読みします",
    "romaji": "およみします",
    "english": "oyomi shimasu",
    "source": "오요미 시마스",
    "added_date": "2026-04-26T03:06:31.667577"
  },
  {
    "id": 1361,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667581"
  },
  {
    "id": 1362,
    "japanese": "",
    "korean": "本人を確認できるものと印鑑はお持ちですか",
    "romaji": "ほんにんをかくにんできるものといんかんはおもちですか",
    "english": "honnin o kakunin dekiru mono to inkan wa omochi desu ka",
    "source": "혼닌오 카쿠닌 데키루 모노토 잉칸와 오모치 데스까",
    "added_date": "2026-04-26T03:06:31.667585"
  },
  {
    "id": 1363,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667589"
  },
  {
    "id": 1364,
    "japanese": "",
    "korean": "お読みください",
    "romaji": "およみください",
    "english": "oyomi kudasai",
    "source": "오요미 쿠다사이",
    "added_date": "2026-04-26T03:06:31.667593"
  },
  {
