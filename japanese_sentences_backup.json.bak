  },
  {
    "id": 2,
    "japanese": "25-08-29",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658783"
  },
  {
    "id": 3,
    "japanese": "",
    "korean": "オヤコドンを食べました。",
    "romaji": "おやこどんをたべました",
    "english": "oyakodon o tabemashita",
    "source": "오야코돈오 타베마시타",
    "added_date": "2026-04-26T03:06:31.658790"
  },
  {
    "id": 4,
    "japanese": "",
    "korean": "両親の誕生日なので、故郷に行く予定です。",
    "romaji": "りょうしんのたんじょうびなので、こきょうにいくよていです",
    "english": "ryoushin no tanjoubi na node, kokyou ni iku yotei desu",
    "source": "료오신노 탄죠오비나노데, 코쿄우니 이쿠 요테이데스",
    "added_date": "2026-04-26T03:06:31.658796"
  },
  {
    "id": 5,
    "japanese": "",
    "korean": "金曜日は英語教室に行きます。",
    "romaji": "きんようびはえいごきょうしつにいきます",
    "english": "kinyoubi wa eigo kyoushitsu ni ikimasu",
    "source": "킨요오비와 에이고 쿄오시츠니 이키마스",
    "added_date": "2026-04-26T03:06:31.658801"
  },
  {
    "id": 6,
    "japanese": "",
    "korean": "友達に会ったり旅行したりしました。",
    "romaji": "ともだちにあったりりょこうしたりしました",
    "english": "tomodachi ni attari ryokou shitari shimashita",
    "source": "토모다치니 앗따리 료코오 시따리 시마시타",
    "added_date": "2026-04-26T03:06:31.658806"
  },
  {
    "id": 7,
    "japanese": "",
    "korean": "コーヒーを飲んだり音楽を聞いたりします。",
    "romaji": "こーひーをのんだりおんがくをきいたりします",
    "english": "koohii o nondari ongaku o kiitari shimasu",
    "source": "코오히이오 논다리 온가쿠오 키이타리 시마스",
    "added_date": "2026-04-26T03:06:31.658811"
  },
  {
    "id": 8,
    "japanese": "",
    "korean": "メニューがちがいます。",
    "romaji": "めにゅーがちがいます。",
    "english": "menyuu ga chigaimasu",
    "source": "메뉴가 치가이마스",
    "added_date": "2026-04-26T03:06:31.658816"
  },
  {
    "id": 9,
    "japanese": "",
    "korean": "동사ます형 어간 + に行く → “~하러 가다”",
    "romaji": "かせぐ → 돈을 벌다",
    "english": "👉 과거형: お金をかせぎに行きました → 돈 벌러 갔습니다.",
    "source": "",
    "added_date": "2026-04-26T03:06:31.658821"
  },
  {
    "id": 10,
    "japanese": "",
    "korean": "",
    "romaji": "はい、よるはあめがふりますね。",
    "english": "hai, yoru wa ame ga furimasu ne",
    "source": "",
    "added_date": "2026-04-26T03:06:31.658826"
  },
  {
    "id": 11,
    "japanese": "",
    "korean": "동사 ます형 + に行く (예: 勉強しに行く → 공부하러 가다)",
    "romaji": "",
    "english": "会う → 会います → 会いに行く",
    "source": "",
    "added_date": "2026-04-26T03:06:31.658831"
  },
  {
    "id": 12,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658836"
  },
  {
    "id": 13,
    "japanese": "",
    "korean": "ごはんを食べに行きます。",
    "romaji": "ごはんをたべにいきます。",
    "english": "gohan o tabe ni ikimasu",
    "source": "고한 오 타베 니 이키마스",
    "added_date": "2026-04-26T03:06:31.658841"
  },
  {
    "id": 14,
    "japanese": "",
    "korean": "映画を見に行きます。",
    "romaji": "えいがをみにいきます。",
    "english": "eiga o mi ni ikimasu",
    "source": "에이가 오 미 니 이키마스",
    "added_date": "2026-04-26T03:06:31.658847"
  },
  {
    "id": 15,
    "japanese": "",
    "korean": "買い物に行きます。",
    "romaji": "かいものにいきます。",
    "english": "kaimono ni ikimasu",
    "source": "카이모노 니 이키마스",
    "added_date": "2026-04-26T03:06:31.658851"
  },
  {
    "id": 16,
    "japanese": "",
    "korean": "ごはんを食べに行きます。",
    "romaji": "ごはんをたべにいきます。",
    "english": "gohan o tabe ni ikimasu",
    "source": "고한오 타베니 이키마스",
    "added_date": "2026-04-26T03:06:31.658856"
  },
  {
    "id": 17,
    "japanese": "",
    "korean": "写真をとりに行きます。",
    "romaji": "しゃしんをとりにいきます。",
    "english": "shashin o tori ni ikimasu",
    "source": "샤신오 토리니 이키마스",
    "added_date": "2026-04-26T03:06:31.658876"
  },
  {
    "id": 18,
    "japanese": "",
    "korean": "今日は雨でした。",
    "romaji": "きょうはあめでした。",
    "english": "kyou wa ame deshita",
    "source": "쿄우와 아메데시타",
    "added_date": "2026-04-26T03:06:31.658881"
  },
  {
    "id": 19,
    "japanese": "",
    "korean": "今はやんでいます。",
    "romaji": "いまはやんでいます。",
    "english": "ima wa yande imasu",
    "source": "이마와 얀데이마스",
    "added_date": "2026-04-26T03:06:31.658890"
  },
  {
    "id": 20,
    "japanese": "",
    "korean": "ご飯を食べに行く",
    "romaji": "ごはんをたべにいく",
    "english": "gohan o tabe ni iku",
    "source": "고한오 타베니 이쿠",
    "added_date": "2026-04-26T03:06:31.658895"
  },
  {
    "id": 21,
    "japanese": "",
    "korean": "本を借りに行く",
    "romaji": "ほんをかりにいく",
    "english": "hon o kari ni iku",
    "source": "혼오 카리니 이쿠",
    "added_date": "2026-04-26T03:06:31.658900"
  },
  {
    "id": 22,
    "japanese": "",
    "korean": "写真をとりに行く",
    "romaji": "しゃしんをとりにいく",
    "english": "shashin o tori ni iku",
    "source": "샤신오 토리니 이쿠",
    "added_date": "2026-04-26T03:06:31.658905"
  },
  {
    "id": 23,
    "japanese": "",
    "korean": "今日は休みの日です。",
    "romaji": "きょうはやすみのひです。",
    "english": "kyou wa yasumi no hi desu",
    "source": "쿄우와 야스미노 히데스",
    "added_date": "2026-04-26T03:06:31.658910"
  },
  {
    "id": 24,
    "japanese": "",
    "korean": "月に一度金曜日に休みます。",
    "romaji": "つきにいちどきんようびにやすみます。",
    "english": "tsuki ni ichido kin'youbi ni yasumimasu",
    "source": "츠키니 이치도 킨요오비니 야스미마스",
    "added_date": "2026-04-26T03:06:31.658915"
  },
  {
    "id": 25,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658920"
  },
  {
    "id": 26,
    "japanese": "",
    "korean": "今日は一日中雨が降っています。",
    "romaji": "きょうはいちにちじゅうあめがふっています。",
    "english": "kyou wa ichinichijuu ame ga futte imasu",
    "source": "쿄우와 이치니치쥬우 아메가 훗테이마스",
    "added_date": "2026-04-26T03:06:31.658925"
  },
  {
    "id": 27,
    "japanese": "",
    "korean": "お金をかせぎに行く",
    "romaji": "おかねをかせぎにいく",
    "english": "okane o kasegi ni iku",
    "source": "오카네오 카세기니 이쿠",
    "added_date": "2026-04-26T03:06:31.658930"
  },
  {
    "id": 28,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658935"
  },
  {
    "id": 29,
    "japanese": "",
    "korean": "本を読んでおく",
    "romaji": "ほんをよんでおく",
    "english": "hon o yonde oku",
    "source": "혼오 욘데 오쿠",
    "added_date": "2026-04-26T03:06:31.658941"
  },
  {
    "id": 30,
    "japanese": "",
    "korean": "ご飯を作っておきます",
    "romaji": "ごはんをつくっておきます",
    "english": "gohan o tsukutte okimasu",
    "source": "고한오 츠쿳테 오키마스",
    "added_date": "2026-04-26T03:06:31.658946"
  },
  {
    "id": 31,
    "japanese": "",
    "korean": "お金をかせいでおきます",
    "romaji": "おかねをかせいでおきます",
    "english": "okane o kaseide okimasu",
    "source": "오카네오 카세이데 오키마스",
    "added_date": "2026-04-26T03:06:31.658953"
  },
  {
    "id": 32,
    "japanese": "",
    "korean": "宿題をしておきます",
    "romaji": "しゅくだいをしておきます",
    "english": "shukudai o shite okimasu",
    "source": "슈쿠다이오 시테 오키마스",
    "added_date": "2026-04-26T03:06:31.658958"
  },
  {
    "id": 33,
    "japanese": "25-09-25",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658963"
  },
  {
    "id": 34,
    "japanese": "",
    "korean": "お腹すいていないんですか",
    "romaji": "おなかすいていないんですか",
    "english": "Onaka suite inai n desu ka",
    "source": "오나카 스이테 이나이응 데스카",
    "added_date": "2026-04-26T03:06:31.658969"
  },
  {
    "id": 35,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658973"
  },
  {
    "id": 36,
    "japanese": "",
    "korean": "朴さんお元気でしたか",
    "romaji": "ぱくさん おげんきでしたか",
    "english": "Paku-san ogenki deshita ka",
    "source": "박쿠상 오겐키 데시타카",
    "added_date": "2026-04-26T03:06:31.658978"
  },
  {
    "id": 37,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658983"
  },
  {
    "id": 38,
    "japanese": "",
    "korean": "駅の前で会いましょう",
    "romaji": "えきのまえで あいましょう",
    "english": "Eki no mae de aimashou",
    "source": "에키노 마에데 아이마쇼-",
    "added_date": "2026-04-26T03:06:31.658988"
  },
  {
    "id": 39,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.658996"
  },
  {
    "id": 40,
    "japanese": "",
    "korean": "一人でできるように勉強しました",
    "romaji": "ひとりで できるように べんきょうしました",
    "english": "Hitori de dekiru you ni benkyou shimashita",
    "source": "히토리데 데키루 요우니 벤쿄우 시마시타",
    "added_date": "2026-04-26T03:06:31.659001"
  },
  {
    "id": 41,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.659006"
  },
  {
    "id": 42,
    "japanese": "",
    "korean": "鈴木さんにいっておきます",
    "romaji": "すずきさんに いっておきます",
    "english": "Suzuki-san ni itte okimasu",
    "source": "스즈키상 니 잇테 오키마스",
    "added_date": "2026-04-26T03:06:31.659011"
  },
  {
    "id": 43,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.659016"
  },
  {
    "id": 44,
    "japanese": "",
    "korean": "おいしい食堂があるそうです",
    "romaji": "おいしい しょくどうが あるそうです",
    "english": "Oishii shokudou ga aru sou desu",
    "source": "오이시 쇼쿠도가 아루 소우 데스",
    "added_date": "2026-04-26T03:06:31.659021"
  },
  {
    "id": 45,
    "japanese": "",
    "korean": "行こうと思います",
    "romaji": "いこうと おもいます",
    "english": "Ikou to omoimasu",
    "source": "이코우토 오모이마스",
    "added_date": "2026-04-26T03:06:31.659026"
  },
  {
    "id": 46,
    "japanese": "",
    "korean": "駅から5分ぐらい歩くと",
    "romaji": "えきから ごふんぐらい あるくと",
    "english": "Eki kara gofun gurai aruku to",
    "source": "에키카라 고훈 구라이 아루쿠토",
    "added_date": "2026-04-26T03:06:31.659031"
  },
  {
