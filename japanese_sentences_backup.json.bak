  {
    "id": 514,
    "japanese": "",
    "korean": "11月24日 月曜日",
    "romaji": "じゅういちがつ にじゅうよっか げつようび",
    "english": "jūichigatsu nijūyokka getsuyōbi",
    "source": "쥬이치가츠 니쥬욧카 게츠요오비",
    "added_date": "2026-04-26T03:06:31.661563"
  },
  {
    "id": 515,
    "japanese": "2025-11-25",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661567"
  },
  {
    "id": 516,
    "japanese": "",
    "korean": "ここは人気のある店で、テレビでも紹介されました。",
    "romaji": "ここは にんきのある みせで、てれびでも しょうかいされました",
    "english": "koko wa ninki no aru mise de, terebi demo shōkai saremashita",
    "source": "코코와 닌키노 아루 미세데, 테레비데모 쇼오카이 사레마시타",
    "added_date": "2026-04-26T03:06:31.661572"
  },
  {
    "id": 517,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.661576"
  },
  {
    "id": 518,
    "japanese": "",
    "korean": "肉を食べ過ぎないように気を付けなければなりません。",
    "romaji": "にくを たべすぎない ように きをつけなければ なりません",
    "english": "niku o tabesuginai yō ni ki o tsukenakereba narimasen",
    "source": "니쿠오 타베스기나이 요오니 키오 츠케나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.661580"
  },
