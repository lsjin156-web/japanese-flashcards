  {
    "id": 354,
    "japanese": "",
    "korean": "会わなければなりません。",
    "romaji": "あわなければなりません。",
    "english": "awanakereba narimasen",
    "source": "아와나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.660672"
  },
  {
    "id": 355,
    "japanese": "2025-10-29",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660680"
  },
  {
    "id": 356,
    "japanese": "",
    "korean": "背が高くて髪が長くないから",
    "romaji": "せがたかくてかみがながくないから",
    "english": "se ga takakute kami ga nagakunai kara",
    "source": "세가 타카쿠테 카미가 나가쿠나이카라",
    "added_date": "2026-04-26T03:06:31.660688"
  },
  {
    "id": 357,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660698"
  },
  {
    "id": 358,
    "japanese": "",
    "korean": "健康のためには野菜がいいです。",
    "romaji": "けんこうのためにはやさいがいいです。",
    "english": "kenkō no tame ni wa yasai ga ii desu",
    "source": "켄코오노 타메니와 야사이가 이이데스",
    "added_date": "2026-04-26T03:06:31.660705"
