    "korean": "方向",
    "romaji": "ほうこう",
    "english": "houkou",
    "source": "호-코-",
    "added_date": "2026-04-26T03:06:31.665366"
  },
  {
    "id": 1095,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
