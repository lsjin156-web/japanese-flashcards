  },
  {
    "id": 1303,
    "japanese": "",
    "korean": "今日は遅く退勤したので食べませんでした。",
    "romaji": "きょう は おそく たいきん した ので たべませんでした",
    "english": "kyou wa osoku taikin shita node tabemasen deshita",
