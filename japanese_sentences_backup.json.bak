    "added_date": "2026-04-26T03:06:31.667884"
  },
  {
    "id": 1427,
    "japanese": "",
    "korean": "栄養もいいです",
    "romaji": "えいようも いいです",
    "english": "eiyou mo ii desu",
    "source": "에이요오모 이이데스",
