    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663289"
  },
  {
    "id": 783,
    "japanese": "",
    "korean": "熱があって、頭が痛いです。",
    "romaji": "ねつが あって あたまが いたいです",
    "english": "netsu ga atte atama ga itai desu",
    "source": "네츠가 앗테 아타마가 이타이 데스",
    "added_date": "2026-04-26T03:06:31.663297"
  },
  {
    "id": 784,
    "japanese": "",
    "korean": "咳が出て、喉が痛いです。",
    "romaji": "せきが でて のどが いたいです",
    "english": "seki ga dete nodo ga itai desu",
    "source": "세키가 데테 노도가 이타이 데스",
    "added_date": "2026-04-26T03:06:31.663306"
  },
  {
    "id": 785,
    "japanese": "",
    "korean": "熱があって、体がだるいです。",
    "romaji": "ねつが あって からだが だるいです",
    "english": "netsu ga atte karada ga darui desu",
    "source": "네츠가 앗테 카라다가 다루이 데스",
    "added_date": "2026-04-26T03:06:31.663314"
  },
  {
    "id": 786,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663322"
  },
  {
    "id": 787,
    "japanese": "",
    "korean": "せきは出ますか。",
    "romaji": "せきは でますか",
    "english": "seki wa demasu ka",
    "source": "세키와 데마스까",
    "added_date": "2026-04-26T03:06:31.663331"
  },
  {
    "id": 788,
    "japanese": "",
    "korean": "せきも出ますか。",
    "romaji": "せきも でますか",
    "english": "seki mo demasu ka",
    "source": "세키모 데마스까",
    "added_date": "2026-04-26T03:06:31.663339"
  },
  {
    "id": 789,
    "japanese": "",
    "korean": "熱は出ましたか。",
    "romaji": "ねつは でましたか",
    "english": "netsu wa demashita ka",
    "source": "네츠와 데마시타까",
    "added_date": "2026-04-26T03:06:31.663348"
  },
  {
    "id": 790,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663356"
  },
  {
    "id": 791,
    "japanese": "",
    "korean": "薬を飲むとすこし眠くなるかもしれません。",
    "romaji": "くすりを のむと すこし ねむく なるかもしれません",
    "english": "kusuri o nomu to sukoshi nemuku naru kamo shiremasen",
    "source": "쿠스리오 노무토 스코시 네무쿠 나루 카모 시레마센",
    "added_date": "2026-04-26T03:06:31.663364"
  },
  {
    "id": 792,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663373"
  },
  {
    "id": 793,
    "japanese": "2025-12-22",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663381"
  },
  {
    "id": 794,
    "japanese": "",
    "korean": "食後に飲んだほうがいいです。",
    "romaji": "しょくごに のんだ ほうが いいです。",
    "english": "shokugo ni nonda hō ga ii desu",
    "source": "쇼쿠고니 논다 호-가 이이데스",
    "added_date": "2026-04-26T03:06:31.663389"
  },
  {
    "id": 795,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663398"
  },
  {
    "id": 796,
    "japanese": "",
    "korean": "飲むと少し眠くなるかもしれません。",
    "romaji": "のむと すこし ねむく なる かもしれません。",
    "english": "nomu to sukoshi nemuku naru kamo shiremasen",
    "source": "노무토 스코시 네무쿠 나루 카모 시레마센",
    "added_date": "2026-04-26T03:06:31.663408"
  },
  {
    "id": 797,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663416"
  },
  {
    "id": 798,
    "japanese": "",
    "korean": "週末は早く出発したほうがいいです。",
    "romaji": "しゅうまつは はやく しゅっぱつ した ほうが いいです。",
    "english": "shūmatsu wa hayaku shuppatsu shita hō ga ii desu",
    "source": "슈-마츠와 하야쿠 슈빳츠 시타 호-가 이이데스",
    "added_date": "2026-04-26T03:06:31.663422"
  },
  {
    "id": 799,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663429"
  },
  {
    "id": 800,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663433"
  },
  {
    "id": 801,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663437"
  },
  {
    "id": 802,
    "japanese": "",
    "korean": "週末は早く出発したほうがいいです。",
    "romaji": "しゅうまつは はやく しゅっぱつしたほうがいいです",
    "english": "shuumatsu wa hayaku shuppatsu shita hou ga ii desu",
    "source": "슈우마츠와 하야쿠 슛파츠 시타 호우가 이이데스",
    "added_date": "2026-04-26T03:06:31.663443"
  },
  {
    "id": 803,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663450"
  },
  {
    "id": 804,
    "japanese": "",
    "korean": "あの店は高くても人気があるようです。",
    "romaji": "あのみせは たかくても にんきがあるようです",
    "english": "ano mise wa takakutemo ninki ga aru you desu",
    "source": "아노 미세와 타카쿠테모 닌키가 아루 요우데스",
    "added_date": "2026-04-26T03:06:31.663455"
  },
  {
    "id": 805,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663459"
  },
  {
    "id": 806,
    "japanese": "",
    "korean": "仕事があれば土曜日も休めません。",
    "romaji": "しごとがあれば どようびも やすめません",
    "english": "shigoto ga areba doyoubi mo yasumemasen",
    "source": "시고토가 아레바 도요우비모 야스메마센",
    "added_date": "2026-04-26T03:06:31.663467"
  },
  {
    "id": 807,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663471"
  },
  {
    "id": 808,
    "japanese": "",
    "korean": "せきが出ます。風邪をひいたかもしれません。",
    "romaji": "せきが でます。かぜを ひいたかもしれません",
    "english": "seki ga demasu kaze o hiita kamo shiremasen",
    "source": "세키가 데마스 가제오 히이타 카모 시레마센",
    "added_date": "2026-04-26T03:06:31.663475"
  },
  {
    "id": 809,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663479"
  },
  {
    "id": 810,
    "japanese": "",
    "korean": "高いですが、人気があるようです。",
    "romaji": "たかいですが、にんきがあるようです",
    "english": "takai desu ga ninki ga aru you desu",
    "source": "타카이 데스가 닌키가 아루 요우데스",
    "added_date": "2026-04-26T03:06:31.663487"
  },
  {
    "id": 811,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663491"
  },
  {
    "id": 812,
    "japanese": "",
    "korean": "高くても人気があります。",
    "romaji": "たかくても にんきが あります",
    "english": "takakutemo ninki ga arimasu",
    "source": "타카쿠테모 닌키가 아리마스",
    "added_date": "2026-04-26T03:06:31.663495"
  },
  {
    "id": 813,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663499"
  },
  {
    "id": 814,
    "japanese": "",
    "korean": "高いですが人気があります。",
    "romaji": "たかいですが にんきが あります",
    "english": "takai desu ga ninki ga arimasu",
    "source": "타카이데스가 닌키가 아리마스",
    "added_date": "2026-04-26T03:06:31.663503"
  },
  {
    "id": 815,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663507"
  },
  {
    "id": 816,
    "japanese": "",
    "korean": "もう会ったかもしれません。",
    "romaji": "もう あったかもしれません",
    "english": "mou atta kamo shiremasen",
    "source": "모우 앗타 카모 시레마센",
    "added_date": "2026-04-26T03:06:31.663511"
  },
  {
    "id": 817,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663515"
  },
  {
    "id": 818,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663520"
  },
  {
    "id": 819,
    "japanese": "",
    "korean": "ごみはいつ出せばいいですか。",
    "romaji": "ごみは いつ だせば いいですか",
    "english": "gomi wa itsu daseba ii desu ka",
    "source": "고미와 이츠 다세바 이이데스카",
    "added_date": "2026-04-26T03:06:31.663526"
  },
  {
    "id": 820,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663530"
  },
  {
    "id": 821,
    "japanese": "",
    "korean": "作ってほしいです。",
    "romaji": "つくって ほしいです",
    "english": "tsukutte hoshii desu",
    "source": "츠쿳테 호시이데스",
    "added_date": "2026-04-26T03:06:31.663533"
  },
  {
    "id": 822,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663537"
  },
  {
    "id": 823,
    "japanese": "",
    "korean": "服を着たまま寝てしまいました。",
    "romaji": "ふくを きたまま ねて しまいました",
    "english": "fuku o kita mama nete shimaimashita",
    "source": "후쿠오 키타 마마 네테 시마이마시타",
    "added_date": "2026-04-26T03:06:31.663541"
  },
  {
    "id": 824,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.663544"
  },
  {
    "id": 825,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663548"
  },
  {
    "id": 826,
    "japanese": "",
    "korean": "キムさんしか入れないです。",
    "romaji": "きむさんしか はいれないです",
    "english": "kimu-san shika hairenai desu",
    "source": "키무상 시카 하이레나이데스",
    "added_date": "2026-04-26T03:06:31.663552"
  },
  {
    "id": 827,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663556"
  },
  {
    "id": 828,
    "japanese": "",
    "korean": "会ったのに別れてしまった。",
    "romaji": "あった のに わかれて しまった",
    "english": "atta noni wakarete shimatta",
    "source": "앗타 노니 와카레테 시맛타",
    "added_date": "2026-04-26T03:06:31.663560"
  },
  {
    "id": 829,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663564"
  },
  {
    "id": 830,
    "japanese": "",
    "korean": "いつ閉めればいいですか。",
    "romaji": "いつ しめれば いいですか",
    "english": "itsu shimeraba ii desu ka",
    "source": "이츠 시메레바 이이데스카",
    "added_date": "2026-04-26T03:06:31.663568"
  },
  {
    "id": 831,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663572"
  },
  {
    "id": 832,
    "japanese": "",
    "korean": "いつ帰ればいいですか。",
    "romaji": "いつ かえれば いいですか",
    "english": "itsu kaereba ii desu ka",
    "source": "이츠 카에레바 이이데스카",
    "added_date": "2026-04-26T03:06:31.663576"
  },
  {
    "id": 833,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663579"
  },
  {
    "id": 834,
    "japanese": "",
    "korean": "カードしか持ってないです。",
    "romaji": "かーどしか もってないです",
    "english": "kaado shika mottenai desu",
    "source": "카아도 시카 못테나이데스",
    "added_date": "2026-04-26T03:06:31.663583"
  },
  {
    "id": 835,
    "japanese": "2025-12-30",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663587"
  },
  {
    "id": 836,
    "japanese": "",
    "korean": "～しか～ないです",
    "romaji": "～しか～ないです",
    "english": "~ shika ~ nai desu",
    "source": "시카 ~ 나이데스",
    "added_date": "2026-04-26T03:06:31.663590"
  },
  {
    "id": 837,
    "japanese": "",
    "korean": "ゴミは木曜日しか出せないです。",
    "romaji": "ごみは もくようび しか だせないです",
    "english": "gomi wa mokuyōbi shika dasenai desu",
    "source": "고미와 모쿠요비 시카 다세나이데스",
    "added_date": "2026-04-26T03:06:31.663594"
  },
  {
    "id": 838,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663600"
  },
  {
    "id": 839,
    "japanese": "",
    "korean": "聞いたのに忘れてしまいました。",
    "romaji": "きいた のに わすれて しまいました",
    "english": "kiita noni wasurete shimaimashita",
    "source": "키이타 노니 와스레테 시마이마시타",
    "added_date": "2026-04-26T03:06:31.663605"
  },
  {
    "id": 840,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663609"
  },
  {
    "id": 841,
    "japanese": "",
    "korean": "部屋の電気がついたままでした。",
    "romaji": "へやの でんきが ついた ままでした。",
    "english": "heya no denki ga tsuita mama deshita",
    "source": "헤야노 덴키가 츠이타 마마데시타",
    "added_date": "2026-04-26T03:06:31.663612"
  },
  {
    "id": 842,
    "japanese": "",
    "korean": "これから気を付けてほしいです。",
    "romaji": "これから きをつけて ほしいです。",
    "english": "korekara ki o tsukete hoshii desu",
    "source": "코레카라 키오 츠케테 호시이데스",
    "added_date": "2026-04-26T03:06:31.663616"
  },
  {
    "id": 843,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663620"
  },
  {
    "id": 844,
