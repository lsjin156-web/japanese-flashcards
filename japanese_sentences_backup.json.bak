  },
  {
    "id": 1196,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666219"
  },
  {
    "id": 1197,
    "japanese": "",
    "korean": "和室",
    "romaji": "わしつ",
    "english": "washitsu",
    "source": "와시츠",
    "added_date": "2026-04-26T03:06:31.666227"
  },
  {
    "id": 1198,
    "japanese": "",
    "korean": "器",
    "romaji": "うつわ",
    "english": "utsuwa",
    "source": "우츠와",
    "added_date": "2026-04-26T03:06:31.666235"
  },
  {
    "id": 1199,
    "japanese": "2026-02-27",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666243"
  },
  {
    "id": 1200,
    "japanese": "",
    "korean": "宿題が面倒くさいです。",
    "romaji": "しゅくだいがめんどうくさいです",
    "english": "shukudai ga mendōkusai desu",
    "source": "슈쿠다이가 멘도오쿠사이 데스",
    "added_date": "2026-04-26T03:06:31.666250"
  },
  {
    "id": 1201,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666259"
  },
  {
    "id": 1202,
    "japanese": "",
    "korean": "面倒くさい",
    "romaji": "めんどうくさい",
    "english": "mendōkusai",
    "source": "멘도오쿠사이",
    "added_date": "2026-04-26T03:06:31.666267"
  },
  {
    "id": 1203,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666275"
  },
  {
    "id": 1204,
    "japanese": "",
    "korean": "持ち帰り用パスタとサラダを食べました",
    "romaji": "もちかえりようぱすたとさらだをたべました",
    "english": "mochikaeri yō pasuta to sarada o tabemashita",
    "source": "모치카에리 요오 파스타토 사라다오 타베마시타",
    "added_date": "2026-04-26T03:06:31.666285"
  },
  {
    "id": 1205,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666293"
  },
  {
    "id": 1206,
    "japanese": "",
    "korean": "女の人は韓国のお茶を上げました",
    "romaji": "おんなのひとはかんこくのおちゃをあげました",
    "english": "onna no hito wa kankoku no ocha o agemashita",
    "source": "온나노 히토와 칸코쿠노 오차오 아게마시타",
    "added_date": "2026-04-26T03:06:31.666301"
  },
  {
    "id": 1207,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666309"
  },
  {
    "id": 1208,
    "japanese": "",
    "korean": "男の人は家が駅から遠くて引っ越すつもりです。",
    "romaji": "おとこのひとはいえがえきからとおくてひっこすつもりです",
    "english": "otoko no hito wa ie ga eki kara tōkute hikkosu tsumori desu",
    "source": "오토코노 히토와 이에가 에키카라 토오쿠테 힛코스 츠모리데스",
    "added_date": "2026-04-26T03:06:31.666318"
  },
  {
    "id": 1209,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666329"
  },
  {
    "id": 1210,
    "japanese": "",
    "korean": "二つ持ってきました",
    "romaji": "ふたつもってきました",
    "english": "futatsu motte kimashita",
    "source": "후타츠 못테 키마시타",
    "added_date": "2026-04-26T03:06:31.666337"
  },
  {
    "id": 1211,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666346"
  },
  {
    "id": 1212,
    "japanese": "2026-03-05",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666354"
  },
  {
    "id": 1213,
    "japanese": "",
    "korean": "韓国は縦で日本は横です。",
    "romaji": "かんこくはたてでにほんはよこです",
    "english": "kankoku wa tate de nihon wa yoko desu",
    "source": "칸코쿠와 타테 데 니혼와 요코 데스",
    "added_date": "2026-04-26T03:06:31.666362"
  },
  {
    "id": 1214,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666370"
  },
  {
    "id": 1215,
    "japanese": "",
    "korean": "お箸の方向が違います。",
    "romaji": "おはしのほうこうがちがいます",
    "english": "ohashi no hōkō ga chigaimasu",
    "source": "오하시노 호-코-가 치가이마스",
    "added_date": "2026-04-26T03:06:31.666379"
  },
  {
    "id": 1216,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666387"
  },
  {
    "id": 1217,
    "japanese": "",
    "korean": "韓国では食事の時器をどうやって食べますか。",
    "romaji": "かんこくではしょくじのときうつわをどうやってたべますか",
    "english": "kankoku dewa shokuji no toki utsuwa o dōyatte tabemasu ka",
    "source": "칸코쿠데와 쇼쿠지노 토키 우츠와오 도얏테 타베마스카",
    "added_date": "2026-04-26T03:06:31.666397"
  },
  {
    "id": 1218,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666405"
  },
  {
    "id": 1219,
    "japanese": "",
    "korean": "器をテーブルの上に置いたまま食べます。",
    "romaji": "うつわをテーブルのうえにおいたままたべます",
    "english": "utsuwa o tēburu no ue ni oita mama tabemasu",
    "source": "우츠와오 테에부루노 우에니 오이타 마마 타베마스",
    "added_date": "2026-04-26T03:06:31.666414"
  },
  {
    "id": 1220,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666422"
  },
  {
    "id": 1221,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666430"
  },
  {
    "id": 1222,
    "japanese": "",
    "korean": "雨が降っていますね。",
    "romaji": "あめがふっていますね",
    "english": "ame ga futte imasu ne",
    "source": "아메가 훗테 이마스네",
    "added_date": "2026-04-26T03:06:31.666438"
  },
  {
    "id": 1223,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666445"
  },
  {
    "id": 1224,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666453"
  },
  {
    "id": 1225,
    "japanese": "",
    "korean": "先週は暑かったですが、今週は寒いです。",
    "romaji": "せんしゅうはあつかったですが こんしゅうはさむいです",
    "english": "senshū wa atsukatta desu ga konshū wa samui desu",
    "source": "센슈와 아츠캇타데스가 콘슈와 사무이데스",
    "added_date": "2026-04-26T03:06:31.666462"
  },
  {
    "id": 1226,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666470"
  },
  {
    "id": 1227,
    "japanese": "",
    "korean": "先週は暑かったのに、今週は寒いですね。",
    "romaji": "せんしゅうはあつかったのに こんしゅうはさむいですね",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666479"
  },
  {
    "id": 1228,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666491"
  },
  {
    "id": 1229,
    "japanese": "",
    "korean": "お茶を入れてきますから、中へどうぞ。",
    "romaji": "おちゃをいれてきますから なかへどうぞ",
    "english": "ocha o irete kimasu kara naka e dōzo",
    "source": "오차오 이레테 키마스카라 나카에 도오조",
    "added_date": "2026-04-26T03:06:31.666500"
  },
  {
    "id": 1230,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666507"
  },
  {
    "id": 1231,
    "japanese": "2026-03-06",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666516"
  },
  {
    "id": 1232,
    "japanese": "",
    "korean": "お茶を入れてきますから。",
    "romaji": "おちゃをいれてきますから。",
    "english": "ocha o irete kimasu kara",
    "source": "오챠오 이레테 키마스 카라",
    "added_date": "2026-04-26T03:06:31.666525"
  },
  {
    "id": 1233,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666533"
  },
  {
    "id": 1234,
    "japanese": "",
    "korean": "飾る",
    "romaji": "かざる",
    "english": "kazaru",
    "source": "카자루",
    "added_date": "2026-04-26T03:06:31.666542"
  },
  {
    "id": 1235,
    "japanese": "",
    "korean": "髪飾り",
    "romaji": "かみかざり",
    "english": "kamikazari",
    "source": "카미카자리",
    "added_date": "2026-04-26T03:06:31.666550"
  },
  {
    "id": 1236,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666559"
  },
  {
    "id": 1237,
    "japanese": "",
    "korean": "ここはきれいな花が飾ってあります。",
    "romaji": "ここはきれいなはながかざってあります。",
    "english": "koko wa kirei na hana ga kazatte arimasu",
    "source": "코코와 키레이나 하나가 카잣테 아리마스",
    "added_date": "2026-04-26T03:06:31.666567"
  },
  {
    "id": 1238,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666576"
  },
  {
    "id": 1239,
    "japanese": "",
    "korean": "箸の方向が違います。",
    "romaji": "はしのほうこうがちがいます。",
    "english": "hashi no houkou ga chigaimasu",
    "source": "하시노 호-코-가 치가이마스",
    "added_date": "2026-04-26T03:06:31.666583"
  },
  {
    "id": 1240,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666591"
  },
  {
    "id": 1241,
    "japanese": "",
    "korean": "韓国は縦で、日本は横です。",
    "romaji": "かんこくはたてで、にほんはよこです。",
    "english": "kankoku wa tate de, nihon wa yoko desu",
    "source": "칸코쿠와 타테데 니혼와 요코 데스",
    "added_date": "2026-04-26T03:06:31.666600"
  },
  {
    "id": 1242,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666607"
  },
  {
    "id": 1243,
    "japanese": "2026-03-11",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666616"
  },
  {
    "id": 1244,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666624"
  },
  {
    "id": 1245,
    "japanese": "",
    "korean": "道はちゃんと説明してあげました。",
    "romaji": "みちはちゃんとせつめいしてあげました",
    "english": "michi wa chanto setsumei shite agemashita",
    "source": "미치와 챤토 세츠메이 시테 아게마시타",
    "added_date": "2026-04-26T03:06:31.666632"
  },
  {
    "id": 1246,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666643"
  },
  {
    "id": 1247,
    "japanese": "",
    "korean": "隣に迷惑をかけてはいけません。",
    "romaji": "となりにめいわくをかけてはいけません",
    "english": "tonari ni meiwaku o kakete wa ikemasen",
    "source": "토나리니 메이와쿠오 카케테와 이케마센",
    "added_date": "2026-04-26T03:06:31.666651"
  },
  {
    "id": 1248,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666662"
  },
  {
    "id": 1249,
    "japanese": "",
    "korean": "健康のためには食べすぎないようにしましょう。",
    "romaji": "けんこうのためにはたべすぎないようにしましょう",
    "english": "kenkou no tame ni wa tabesuginai you ni shimashou",
    "source": "켄코노 타메니와 타베스기나이 요우니 시마쇼",
    "added_date": "2026-04-26T03:06:31.666670"
  },
  {
    "id": 1250,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666678"
  },
  {
    "id": 1251,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666687"
  },
  {
    "id": 1252,
    "japanese": "",
    "korean": "日本語が話せますか。",
    "romaji": "にほんごがはなせますか",
    "english": "nihongo ga hanasemasu ka",
    "source": "니혼고가 하나세마스카",
    "added_date": "2026-04-26T03:06:31.666694"
  },
  {
    "id": 1253,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666702"
  },
  {
    "id": 1254,
    "japanese": "",
    "korean": "金曜日は行けません。",
    "romaji": "きんようびはいけません",
    "english": "kinyoubi wa ikemasen",
    "source": "킨요오비와 이케마센",
    "added_date": "2026-04-26T03:06:31.666710"
  },
  {
    "id": 1255,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666721"
  },
  {
    "id": 1256,
    "japanese": "",
    "korean": "パクさんは漢字が書けれます。",
    "romaji": "ぱくさんはかんじがかけれます",
    "english": "pakusan wa kanji ga kakeremasu",
    "source": "파쿠상와 칸지가 카케레마스",
    "added_date": "2026-04-26T03:06:31.666729"
  },
  {
    "id": 1257,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666737"
  },
  {
    "id": 1258,
    "japanese": "",
    "korean": "お父さんはお酒が飲めません。",
    "romaji": "おとうさんはおさけがのめません",
    "english": "otousan wa osake ga nomemasen",
    "source": "오토상와 오사케가 노메마센",
    "added_date": "2026-04-26T03:06:31.666745"
  },
  {
    "id": 1259,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666752"
  },
  {
    "id": 1260,
    "japanese": "",
    "korean": "일본어",
    "romaji": "히라가나",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666760"
  },
  {
    "id": 1261,
    "japanese": "",
    "korean": "お父さんはお酒が飲めません。",
    "romaji": "おとうさんはおさけがのめません",
    "english": "otousan wa osake ga nomemasen",
    "source": "오토상와 오사케가 노메마센",
    "added_date": "2026-04-26T03:06:31.666768"
  },
  {
    "id": 1262,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666775"
  },
  {
    "id": 1263,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666784"
  },
  {
    "id": 1264,
    "japanese": "",
    "korean": "週末に食べて残った",
    "romaji": "しゅうまつにたべてのこった",
    "english": "shuumatsu ni tabete nokotta",
    "source": "슈우마츠니 타베테 노콧타",
    "added_date": "2026-04-26T03:06:31.666792"
  },
  {
    "id": 1265,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666800"
  },
  {
    "id": 1266,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666808"
  },
  {
    "id": 1267,
    "japanese": "",
    "korean": "宝くじに当たる",
    "romaji": "たからくじにあたる",
    "english": "takarakuji ni ataru",
    "source": "타카라쿠지니 아타루",
    "added_date": "2026-04-26T03:06:31.666818"
  },
  {
    "id": 1268,
    "japanese": "2026-03-13",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666826"
  },
  {
    "id": 1269,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666834"
  },
  {
    "id": 1270,
    "japanese": "",
    "korean": "ここはテレビでも紹介されました。",
    "romaji": "ここはてれびでもしょうかいされました",
    "english": "koko wa terebi demo shoukai saremashita",
    "source": "코코와 테레비데모 쇼오카이 사레마시타",
    "added_date": "2026-04-26T03:06:31.666842"
  },
  {
    "id": 1271,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666850"
  },
  {
    "id": 1272,
    "japanese": "",
    "korean": "電車の中で足をふまれました。",
    "romaji": "でんしゃのなかであしをふまれました",
    "english": "densha no naka de ashi o fumaremashita",
    "source": "덴샤노 나카데 아시오 후마레마시타",
    "added_date": "2026-04-26T03:06:31.666858"
  },
  {
    "id": 1273,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666872"
  },
  {
    "id": 1274,
    "japanese": "",
    "korean": "ヤンさんは7時までには来られます。",
    "romaji": "やんさんはしちじまでにはこられます",
    "english": "yan san wa shichiji made ni wa koraremasu",
    "source": "얀상와 시치지마데니와 코라레마스",
    "added_date": "2026-04-26T03:06:31.666880"
  },
  {
    "id": 1275,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666891"
  },
  {
    "id": 1276,
    "japanese": "",
    "korean": "ヤンさんはいつもお母さんにほめられます。",
    "romaji": "やんさんはいつもおかあさんにほめられます",
    "english": "yan san wa itsumo okaasan ni homeraremasu",
    "source": "얀상와 이츠모 오카아상니 호메라레마스",
    "added_date": "2026-04-26T03:06:31.666901"
  },
  {
    "id": 1277,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666910"
  },
  {
    "id": 1278,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666918"
  },
  {
    "id": 1279,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "Romaji",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666927"
  },
  {
    "id": 1280,
    "japanese": "",
    "korean": "風が強かった。",
    "romaji": "かぜがつよかった",
    "english": "kaze ga tsuyokatta",
    "source": "카제가 츠요캇타",
    "added_date": "2026-04-26T03:06:31.666935"
  },
  {
    "id": 1281,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "Romaji",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666943"
  },
  {
    "id": 1282,
    "japanese": "",
    "korean": "午前に天気がいいので",
    "romaji": "ごぜんにてんきがいいので",
    "english": "gozen ni tenki ga ii node",
    "source": "고젠니 텐키가 이이 노데",
    "added_date": "2026-04-26T03:06:31.666951"
  },
  {
    "id": 1283,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "Romaji",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666958"
  },
  {
    "id": 1284,
    "japanese": "",
    "korean": "天気が良かったので",
    "romaji": "てんきがよかったので",
    "english": "tenki ga yokatta node",
    "source": "텐키가 요캇타 노데",
