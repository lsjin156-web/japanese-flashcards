  {
    "id": 1157,
    "japanese": "2026-02-24",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665894"
  },
  {
    "id": 1158,
    "japanese": "",
    "korean": "両方のご両親はお元気でしょうか。",
    "romaji": "りょうほうの ごりょうしん は おげんき でしょうか",
    "english": "ryōhō no goryōshin wa ogenki deshō ka",
    "source": "료-호-노 고료-신 와 오겐키 데쇼-카",
    "added_date": "2026-04-26T03:06:31.665903"
  },
  {
    "id": 1159,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665911"
  },
  {
    "id": 1160,
    "japanese": "",
    "korean": "二人兄弟",
    "romaji": "ふたりきょうだい",
    "english": "futari kyōdai",
    "source": "후타리 쿄-다이",
    "added_date": "2026-04-26T03:06:31.665918"
  },
  {
    "id": 1161,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665926"
  },
  {
    "id": 1162,
    "japanese": "",
    "korean": "三時間半かかりました。",
    "romaji": "さんじかんはん かかりました",
    "english": "sanjikan han kakarimashita",
    "source": "산지칸 한 카카리마시타",
    "added_date": "2026-04-26T03:06:31.665934"
  },
  {
    "id": 1163,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665943"
  },
  {
    "id": 1164,
    "japanese": "",
    "korean": "午前一時に帰りましたが木曜日から出勤でした。",
    "romaji": "ごぜんいちじ に かえりました が もくようび から しゅっきん でした",
    "english": "gozen ichiji ni kaerimashita ga mokuyōbi kara shukkin deshita",
    "source": "고젠 이치지 니 카에리마시타 가 모쿠요-비 카라 슛킨 데시타",
    "added_date": "2026-04-26T03:06:31.665951"
  },
  {
    "id": 1165,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665959"
  },
  {
    "id": 1166,
    "japanese": "",
    "korean": "妹が一人います。",
    "romaji": "いもうと が ひとり います",
    "english": "imōto ga hitori imasu",
    "source": "이모-토 가 히토리 이마스",
    "added_date": "2026-04-26T03:06:31.665967"
  },
  {
    "id": 1167,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.665975"
  },
  {
    "id": 1168,
    "japanese": "",
    "korean": "何人兄弟ですか。",
    "romaji": "なんにん きょうだい ですか",
    "english": "nannin kyōdai desu ka",
    "source": "난닌 쿄-다이 데스카",
    "added_date": "2026-04-26T03:06:31.665983"
  },
  {
    "id": 1169,
    "japanese": "",
    "korean": "一人だけです。",
    "romaji": "ひとり だけ です",
    "english": "hitori dake desu",
    "source": "히토리 다케 데스",
    "added_date": "2026-04-26T03:06:31.665991"
  },
  {
    "id": 1170,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666003"
  },
  {
    "id": 1171,
    "japanese": "",
    "korean": "結婚しました。",
    "romaji": "けっこん しました",
    "english": "kekkon shimashita",
    "source": "켓콘 시마시타",
    "added_date": "2026-04-26T03:06:31.666011"
  },
  {
    "id": 1172,
    "japanese": "",
    "korean": "結婚しています。",
    "romaji": "けっこん しています",
    "english": "kekkon shite imasu",
    "source": "켓콘 시테 이마스",
    "added_date": "2026-04-26T03:06:31.666019"
  },
  {
    "id": 1173,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666027"
  },
  {
    "id": 1174,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666035"
  },
  {
    "id": 1175,
    "japanese": "",
    "korean": "明日来られるかどうか聞いてみます。",
    "romaji": "あした こられる か どうか きいて みます",
    "english": "ashita korareru ka dō ka kiite mimasu",
    "source": "아시타 코라레루 카 도-카 키이테 미마스",
    "added_date": "2026-04-26T03:06:31.666043"
  },
  {
    "id": 1176,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666052"
  },
  {
    "id": 1177,
    "japanese": "",
    "korean": "キムさんに会えるかどうかよくわかりません。",
    "romaji": "きむさん に あえる か どうか よく わかりません",
    "english": "kimu-san ni aeru ka dō ka yoku wakarimasen",
    "source": "키무상 니 아에루 카 도-카 요쿠 와카리마센",
    "added_date": "2026-04-26T03:06:31.666060"
  },
  {
    "id": 1178,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666068"
  },
  {
    "id": 1179,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666077"
  },
  {
    "id": 1180,
    "japanese": "",
    "korean": "結婚するつもりです。",
    "romaji": "けっこん する つもり です",
    "english": "kekkon suru tsumori desu",
    "source": "켓콘 스루 츠모리 데스",
    "added_date": "2026-04-26T03:06:31.666085"
  },
  {
    "id": 1181,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666093"
  },
  {
    "id": 1182,
    "japanese": "",
    "korean": "髪も切るつもりです。",
    "romaji": "かみ も きる つもり です",
    "english": "kami mo kiru tsumori desu",
    "source": "카미 모 키루 츠모리 데스",
    "added_date": "2026-04-26T03:06:31.666101"
  },
  {
    "id": 1183,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자 발음",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666109"
  },
  {
    "id": 1184,
    "japanese": "",
    "korean": "美容室に行く予定です。",
    "romaji": "びようしつ に いく よてい です",
    "english": "biyōshitsu ni iku yotei desu",
    "source": "비요-시츠 니 이쿠 요테이 데스",
    "added_date": "2026-04-26T03:06:31.666118"
  },
  {
    "id": 1185,
    "japanese": "2026-02-25",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666126"
  },
  {
    "id": 1186,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666133"
  },
  {
    "id": 1187,
    "japanese": "",
    "korean": "明日来られるかどうか聞いてみます。",
    "romaji": "あした こられる か どうか きいてみます。",
    "english": "ashita korareru ka douka kiite mimasu",
    "source": "아시타 코라레루 카 도-카 키이테 미마스",
    "added_date": "2026-04-26T03:06:31.666141"
  },
  {
    "id": 1188,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666149"
  },
  {
    "id": 1189,
    "japanese": "",
    "korean": "田舎で暮らすつもりです。",
    "romaji": "いなかで くらす つもりです。",
    "english": "inaka de kurasu tsumori desu",
    "source": "이나카데 쿠라스 츠모리데스",
    "added_date": "2026-04-26T03:06:31.666160"
  },
  {
    "id": 1190,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666168"
  },
  {
    "id": 1191,
    "japanese": "",
    "korean": "持ち帰り用のパスタとサラダを食べました。",
    "romaji": "もちかえりよう の パスタ と サラダ を たべました。",
    "english": "mochikaeri you no pasuta to sarada o tabemashita",
    "source": "모치카에리요-노 파스타토 사라다오 타베마시타",
    "added_date": "2026-04-26T03:06:31.666176"
  },
  {
    "id": 1192,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.666187"
  },
  {
    "id": 1193,
    "japanese": "",
    "korean": "めんどくさいですね。",
    "romaji": "めんどくさい です ね。",
    "english": "mendokusai desu ne",
    "source": "멘도쿠사이 데스네",
    "added_date": "2026-04-26T03:06:31.666195"
  },
  {
    "id": 1194,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.666203"
  },
  {
    "id": 1195,
