  {
    "id": 209,
    "japanese": "질문",
    "korean": "季節の中でいつが一番好きですか。",
    "romaji": "きせつのなかで いつが いちばん すきですか。",
    "english": "kisetsu no naka de itsu ga ichiban suki desu ka",
    "source": "키세츠노 나카데 이츠가 이치방 스키데스카",
    "added_date": "2026-04-26T03:06:31.659856"
  },
  {
    "id": 210,
    "japanese": "대답",
    "korean": "冬が一番好きです。",
    "romaji": "ふゆが いちばん すきです。",
    "english": "fuyu ga ichiban suki desu",
    "source": "후유가 이치방 스키데스",
    "added_date": "2026-04-26T03:06:31.659871"
  },
