  {
    "id": 775,
    "japanese": "",
    "korean": "喉がはれていますね。",
    "romaji": "のどが はれていますね",
    "english": "nodo ga harete imasu ne",
    "source": "노도가 하레테 이마스네",
    "added_date": "2026-04-26T03:06:31.663231"
  },
  {
    "id": 776,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.663238"
  },
  {
    "id": 777,
    "japanese": "",
    "korean": "喉が痛いです。",
    "romaji": "のどが いたいです",
    "english": "nodo ga itai desu",
    "source": "노도가 이타이 데스",
    "added_date": "2026-04-26T03:06:31.663246"
  },
  {
    "id": 778,
    "japanese": "",
    "korean": "喉が赤いですね。",
    "romaji": "のどが あかいですね",
    "english": "nodo ga akai desu ne",
    "source": "노도가 아카이 데스네",
    "added_date": "2026-04-26T03:06:31.663254"
  },
  {
    "id": 779,
    "japanese": "",
    "korean": "喉がはれているようです。",
    "romaji": "のどが はれているようです",
    "english": "nodo ga harete iru yō desu",
    "source": "노도가 하레테 이루 요오 데스",
    "added_date": "2026-04-26T03:06:31.663262"
  },
