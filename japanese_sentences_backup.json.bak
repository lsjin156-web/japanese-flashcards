  {
    "id": 370,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660779"
  },
  {
    "id": 371,
    "japanese": "",
    "korean": "安いものは少なく高いものばかりですね",
    "romaji": "やすいものはすくなくたかいものばかりですね",
    "english": "yasui mono wa sukunaku takai mono bakari desu ne",
    "source": "야스이 모노와 스쿠나쿠 타카이 모노 바카리데스네",
    "added_date": "2026-04-26T03:06:31.660784"
  },
  {
    "id": 372,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660789"
  },
  {
    "id": 373,
    "japanese": "",
    "korean": "さいふはこれだけでしょう。もうないです。",
    "romaji": "さいふはこれだけでしょう。もうないです。",
    "english": "saifu wa kore dake deshō. mō nai desu.",
    "source": "사이후와 코레다케 데쇼오. 모오 나이데스.",
    "added_date": "2026-04-26T03:06:31.660794"
  },
  {
    "id": 374,
    "japanese": "",
    "korean": "",
    "romaji": "",
    "english": "",
    "source": "",
    "added_date": "2026-04-26T03:06:31.660799"
  },
  {
    "id": 375,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660804"
  },
  {
    "id": 376,
    "japanese": "",
    "korean": "ご注文のすき焼きでございます。",
    "romaji": "ごちゅうもんのすきやきでございます。",
    "english": "gochūmon no sukiyaki de gozaimasu",
    "source": "고츄우몬노 스키야키데고자이마스",
    "added_date": "2026-04-26T03:06:31.660809"
  },
  {
    "id": 377,
    "japanese": "",
    "korean": "ごゆっくりどうぞ。",
    "romaji": "ごゆっくりどうぞ。",
    "english": "go yukkuri dōzo",
    "source": "고 윳쿠리 도우조",
    "added_date": "2026-04-26T03:06:31.660814"
  },
  {
    "id": 378,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660819"
  },
  {
    "id": 379,
    "japanese": "",
    "korean": "あ、お肉が とても やわらかく なりましたね。",
    "romaji": "あ、おにくが とても やわらかく なりましたね。",
    "english": "a, oniku ga totemo yawarakaku narimashita ne",
    "source": "아, 오니쿠가 토테모 야와라카쿠 나리마시타네",
    "added_date": "2026-04-26T03:06:31.660824"
  },
  {
    "id": 380,
    "japanese": "",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.660829"
  },
  {
    "id": 381,
    "japanese": "",
    "korean": "食べすぎてしまうから 気をつけなければなりません。",
    "romaji": "たべすぎてしまうから きをつけなければなりません。",
    "english": "tabesugite shimau kara ki o tsukenakereba narimasen",
    "source": "타베스기테 시마우카라 키오 츠케나케레바 나리마센",
    "added_date": "2026-04-26T03:06:31.660834"
  },
