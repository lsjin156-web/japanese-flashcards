  },
  {
    "id": 1391,
    "japanese": "2026-04-10",
    "korean": "일본어",
    "romaji": "ひらがな",
    "english": "로마자",
    "source": "한글 발음",
    "added_date": "2026-04-26T03:06:31.667714"
  },
  {
    "id": 1392,
    "japanese": "",
    "korean": "道が混んでいますか。",
    "romaji": "みちがこんでいますか",
    "english": "michi ga konde imasu ka",
    "source": "미치가 콘데 이마스까",
    "added_date": "2026-04-26T03:06:31.667723"
  },
  {
    "id": 1393,
